          <EntitySet Name="faktnewtbl" EntityType="Self.faktnewtbl" store:Type="Tables" store:Schema="dbo">
            <DefiningQuery>SELECT 
[faktnewtbl].[IdSprawy] AS [IdSprawy], 
[faktnewtbl].[sygnatura] AS [sygnatura], 
[faktnewtbl].[NrKlienta] AS [NrKlienta], 
[faktnewtbl].[IdNaleznosci] AS [IdNaleznosci], 
[faktnewtbl].[Nrfaktury] AS [Nrfaktury], 
[faktnewtbl].[DataFaktury] AS [DataFaktury], 
[faktnewtbl].[data_n] AS [data_n], 
[faktnewtbl].[kwota] AS [kwota], 
[faktnewtbl].[vat] AS [vat], 
[faktnewtbl].[zaleglosc] AS [zaleglosc], 
[faktnewtbl].[dzis] AS [dzis], 
[faktnewtbl].[IdDlu] AS [IdDlu], 
[faktnewtbl].[Nazwa] AS [Nazwa], 
[faktnewtbl].[Miejscowosc] AS [Miejscowosc], 
[faktnewtbl].[ulica] AS [ulica], 
[faktnewtbl].[kod] AS [kod], 
[faktnewtbl].[Nip] AS [Nip], 
[faktnewtbl].[pesel] AS [pesel]
FROM [dbo].[faktnewtbl] AS [faktnewtbl]</DefiningQuery>
          </EntitySet>
          <EntitySet Name="SSIS Configurations" EntityType="Self.SSIS Configurations" store:Type="Tables" store:Schema="dbo">
            <DefiningQuery>SELECT 
