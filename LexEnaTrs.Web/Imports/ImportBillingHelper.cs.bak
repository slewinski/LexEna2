                                        break;
                                    case 3: // olsztyn

                                        li_rejon = 606;
                                        break;
                                    case 4: // ostróda

                                        li_rejon = 608;
                                        break;
                                    case 5: // szczytno

                                        li_rejon = 610;
                                        break;
                                    case 6: // Iława

                                        li_rejon = 607;
                                        break;
