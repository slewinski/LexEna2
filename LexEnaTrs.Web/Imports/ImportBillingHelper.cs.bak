                                        break;
                                }
                                break;
                            case "ENKL":
                            case "KALISZ":
                                switch (li_rejon)
                                {
                                    case 1:  // kalisz

                                        li_rejon = 414;
                                        break;
                                    case 2:

                                        li_rejon = 416;  // ostrów wielkopolski
                                        break;
                                    case 3:

                                        li_rejon = 417;  // Kępno
                                        break;
                                    case 4:

                                        li_rejon = 418; // jarocin
                                        break;
                                    case 5:

                                        li_rejon = 419; //  Konin
                                        break;
                                    case 6:

