  <data name="UZD_FakturyPakietuMainDS.SelectCommand" xml:space="preserve">
    <value>select  f.Nazwa, f.NIP, f.NrFaktury, convert(varchar(10),f.DataFaktury,105) as DataFaktury , 
 convert(varchar(10),f.DataWymagalnosci,105) DataWymagalnosci, f.Zaleglosc - cast(round((f.Zaleglosc *vat)/Kwota,2,1) as decimal(18,2)) as Netto ,
 cast(round((f.Zaleglosc *vat)/Kwota,2,1)  as decimal(18,2)) as Vat , f.Zaleglosc, f.Sygnatura, f.Kwota , f.vat as VatStart , f.DataWeryfNIP, f.StatusWalidNIP,  convert(varchar(10),DataUlgi,120) as DataPoczUlgi,  
convert (varchar(7),DataUlgi ,120) as  OkresPodatkowy, cast(DATEPART(yy,DataUlgi) as varchar(4)) +  '-' + cast(DATEPART(qq,DataUlgi) as varchar(1)) as KwartalPodatkowy
, year(f.DataWymagalnosci) as RokWymag, pk.DataTypowania ,
f.Uzd_FakturaId as IdNal, f.IdNalWiena as IdNalWiena, convert(varchar(10),f.DataSprzedazy,105)  as DataSprzedazy
from  UZD_Faktura  f inner join UZD_Pakiet pk on f.UZD_PakietId = pk.UZD_PakietId
where f.Uzd_pakietId = @IdPakiet and 
( (@Mode = 1 and f.StatusWalidNip = 1 and isnull(f.status,1) &gt;= 0) or (@Mode = 2 and f.StatusWalidNip = 1 and f.Status &gt; 0 ) or (isnull(@Mode,0) = 0))
 order by f.Uzd_FakturaId </value>
  </data>
