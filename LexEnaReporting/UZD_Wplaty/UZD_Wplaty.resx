  <data name="UZD_WplatyDS.SelectCommand" xml:space="preserve">
    <value> select 'EZ' as rodznumerajDok ,  convert (varchar(10), case when uf.Status &lt; 0  then uf.DataFaktury else uw.DataWpl end ,104) as DataWplaty, '' as DataKsiegowania, convert (varchar(10),case when udw.DataSprzedazy is null then uf.DataSprzedazy else udw.DataSprzedazy end  ,104)  as DataSprzedazy,
 case when uf.Status &lt; 0  then  convert(varchar(10),uf.DataUlgi,104) else  convert (varchar(10), uw.DataWpl  ,104)  end as DataNaglVAT, 
case when len(uf.NrFaktury)&gt;16 then substring(uf.NrFaktury, len(uf.NrFaktury)-15  ,16) else uf.Nrfaktury end as NrFaktury
,  usm.SAPId as NrOdbiorcy  
, uw.Kwota as Brutto, uw.Kwota - uw.KwotaVAT  as Netto , uw.KwotaVAT as VAT, convert (varchar(10),uw.DataZapisu,104) as DataZapisu , uw.KwotaW as KwotaWplaty , 
'wpłata do f:' + uf.nrfaktury as opis, uf.sygnatura, uf.Nazwa, uw.Tytul 
from UZD_Wplata uw  inner join UZD_Faktura uf  on uw.UZD_FakturaId = uf.UZD_FakturaId  left outer join  UZD_SapMap usm 
on usm.NIP = uf.nip
left outer join UZD_DataFakturyDW  udw on uf.NrFaktury = udw.NrFaktury

where  uw.UZD_PakietWplatId =	@IdPakiet   and uw.status &gt;= 0  order by uw.dataWpl 
</value>
  </data>
