  <data name="DSKonta.SelectCommand" xml:space="preserve">
    <value>select distinct ka.konto as konto,   isnull((select top 1 kc.id from konto kc where ka.konto = kc.konto and kc.id_firmy = 1 ),0) as id_eob, ka.rodzaj as rodzaj from konto ka where ka.aktywne = 1 and ka.rodzaj &gt;= 0 and len( rtrim(isnull(ka.konto,''))) &gt; 0  order by ka.rodzaj asc , ka.konto asc</value>
  </data>
  <data name="DSDziennikObroty.SelectCommand" xml:space="preserve">
    <value>SELECT  konto.konto,konto_anal.numer, oj.id_sprawy, oj.d_operacji, oj.winien,oj.ma,oj.vat, oj.energia,oj.wdz,oj.koszty,oj.odsetki,oj.ods_kapital,oj.ods_naliczone,oj.rodzaj,oj.inne,oj.nr_dowodu,s.sygnatura, oj.ident,s.ident,(select top 1 rtrim(sk.nazwisko + ' ' + isnull(sk.imie,'')) from skazani sk inner join spr_dluz sdl on sdl.id_dluz = sk.id where  sdl.id_sprawy = s.ident) as Dluznik ,konto_anal.id_konta,zlc.nr_dziennika as NrDziennikaFROM 
 obroty oj LEFT OUTER JOIN sprawa s ON oj.id_sprawy = s.ident left outer join zlecenia_ksiegowe zlc on oj.id_schemat = zlc.ident, konto , konto_anal   WHERE (konto_anal.id_konta = konto.id) AND( oj.id_konta = konto_anal.ident ) and ( oj.czyus = 0 ) 
and oj.d_operacji &gt;= @DataOd and oj.d_operacji &lt;= @DataDo and s.id_firmy in (@Oddzialy)
and konto.id in (@Konta)
ORDER BY konto.konto asc , konto_anal.numer asc, oj.d_operacji Asc, oj.ident Asc</value>
  </data>
