  <data name="SpaduZEPUDS.SelectCommand" xml:space="preserve">
    <value>select distinct s.sygnatura as Wiena, 
	  ( select  top 1 replace(replace(isnull(skz.nazwisko,'') + ' ' + isnull(skz.imie,''),'"',''),';','')
		  from  wiena_eob_prod.dbo.skazani skz WITH (NOLOCK) inner join   wiena_eob_prod.dbo.spr_dluz WITH (NOLOCK) on skz.id = spr_dluz.id_dluz 
		   where spr_dluz.id_sprawy = s.ident order by spr_dluz.ident asc ) as "Dane",
		   tn.nazwa as "Należność", 
		   nal.tytul as "Tytułem",
		   Convert(varchar(10),nal.data_n,105) as "Data wymagalności",
		   nal.kwota as "Kwota",
		   isnull((select top 1  ns.kwota_n  from wiena_eob_prod.dbo.nal_stan ns where ns.id_nal = nal.ident order by ns.data_s desc) ,nal.kwota) as "Zaległość",
		   isnull((select top 1  ns.kwota_o  from wiena_eob_prod.dbo.nal_stan ns where ns.id_nal = nal.ident order by ns.data_s desc) ,0) as "Odsetki"

from wiena_eob_prod.dbo.sprawa s  inner join  wiena_eob_prod.dbo.naleznosc nal on nal.id_sprawy = s.ident inner join wiena_eob_prod.dbo.typ_nal tn on nal.id_typ_nal = tn.ident
inner join wiena_eob_prod.dbo.firma f on s.id_firmy = f.ident
 where  f.typ_firmy = 1 and  tn.typ_nal in (1,4) and  s.sygnatura in (select * from dbo.SplitNumbers(@Sygnatury))
 order by s.sygnatura</value>
  </data>
