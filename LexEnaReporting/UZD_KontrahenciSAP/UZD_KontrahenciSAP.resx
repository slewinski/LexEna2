  <data name="UZD_KontrahenciSapDS.SelectCommand" xml:space="preserve">
    <value>with nipy as
(
select max( u.DataWymagalnosci) as data, u.nip as nip from UZD_Faktura u 
where u.UZD_PakietId = @IdPakiet
and u.Status&gt;=0 and u.StatusWalidNip = 1 and u.Nazwa is not null and len(ltrim(rtrim(nip)))&gt;0 
group by u.nip
),
pesele as
(
select max( u.DataWymagalnosci) as data, u.pesel as pesel from UZD_Faktura u 
where u.UZD_PakietId = @IdPakiet
and u.Status&gt;=0 and u.StatusWalidNip = 1 and u.Nazwa is not null and len(ltrim(rtrim(isnull(nip,''))))=0 and len(ltrim(rtrim(isnull(pesel,''))))=11
group by u.pesel
)
select distinct  
replace(replace(replace(replace(substring (u.Nazwa,1,35),'"',''),'''',''),',,',''),'´','') as Nazwa1,  replace(replace(replace(replace(substring (u.Nazwa,36,35),'"',''),'''',''),',,',''),'´','') as Nazwa2, replace(replace(replace(replace(substring (u.Nazwa,71,35),'''',''),'"',''),',,',''),'´','') as Nazwa3, replace(replace(replace(replace(substring (u.Nazwa,106,35),'"',''),'''',''),',,',''),'´','') as Nazwa4,
--case when   SUBSTRING(u.nazwa,CHARINDEX('"',u.nazwa)+1,CHARINDEX('"',u.nazwa)-CHARINDEX('"',u.nazwa)-1),
 replace(replace(replace(case when patindex('%"%"%',u.nazwa) &gt; 0 then 
    substring(substring(u.nazwa,charindex( '"',u.nazwa,1) + 1 , charindex('"',u.nazwa,charindex('"', u.nazwa,1) + 1) - charindex('"', u.nazwa,1) - 1),1,20) 
 else substring(replace(u.nazwa,'"',''),1,20)end ,'"',''),'''',''),',,','')   as Skrot,
 
 u.Nazwa,  u.NIP, isnull(u.Pesel,'') as pesel, case when len(u.Pesel) = 11 then 'X' else '' end as czyFIZ , substring(u.Kod,1,2) +'-' + substring(u.Kod,3,3) as Kod , u.Miejscowosc, u.Ulica , u.NrKlienta  from UZD_faktura u 
inner join  nipy n on u.DataWymagalnosci = n.data and n.nip = u.Nip

where UZD_PakietId = @IdPakiet
and not exists(select null from UZD_SapMap usm where usm.NIp = u.nip and len(ltrim(rtrim(usm.SAPId))) &gt; 0  ) 
and u.Status&gt;=0 and u.StatusWalidNip = 1 and Nazwa is not null
and u.nip not in 
