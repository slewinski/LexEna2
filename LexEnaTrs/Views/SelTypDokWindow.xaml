<controls:ChildWindow x:Class="LexEnaTrs.Views.SelTypDokWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
           xmlns:controls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls"
           xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"           
           Width="247" Height="300" 
           Title="Wybierz rodzaj  dokumentu">
    <Grid x:Name="LayoutRoot" Margin="2">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Button x:Name="CancelButton" Content="Anuluj" Click="CancelButton_Click" Width="75" Height="23" HorizontalAlignment="Right" Margin="0,12,0,0" Grid.Row="1" />
        <Button x:Name="OKButton" Content="OK" Click="OKButton_Click" Width="75" Height="23" HorizontalAlignment="Right" Margin="0,12,79,0" Grid.Row="1" />
        <telerik:RadGridView x:Name="GridViewSelTypDok" RowIndicatorVisibility="Collapsed" IsReadOnly="True"  AutoGenerateColumns="False" ItemsSource="{Binding typDokumentu, Source={StaticResource SlownikRodzajeDokumentow}}" ShowColumnHeaders="False" ShowGroupPanel="False">
            <telerik:RadGridView.Columns>
                <telerik:GridViewDataColumn Header="Nazwa jednostki" DataMemberBinding="{Binding Nazwa}" Width="*" />
                <!--<telerik:GridViewDataColumn DataMemberBinding="(Binding Id}" />-->
            </telerik:RadGridView.Columns>
        </telerik:RadGridView>
    </Grid>
</controls:ChildWindow>