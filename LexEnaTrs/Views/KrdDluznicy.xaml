<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:riaControls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls.DomainServices" xmlns:my="clr-namespace:LexEnaTrs.Web" xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation" x:Class="LexEnaTrs.Views.KrdDluznicy"
    mc:Ignorable="d"
    xmlns:local="clr-namespace:LexEnaTrs" 
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:DesignHeight="592" d:DesignWidth="800" Loaded="UserControl_Loaded">

    <Grid x:Name="LayoutRoot" Background="White">

        <telerik:RadDomainDataSource AutoLoad="False" Height="0" PageSize="100"   x:Name="BIGvw_Dluznicydds" QueryName="GetBIGvw_DluznicyQuery" Width="0"  LoadingData="GetBIG_ImportByDate_LoadingData" LoadedData="BIGvw_Dluznicydds_LoadedData">
            <telerik:RadDomainDataSource.DomainContext>
                <my:LexEnaMeritumDomainContext />
            </telerik:RadDomainDataSource.DomainContext>

        </telerik:RadDomainDataSource>
        <telerik:RadDomainDataSource AutoLoad="False" Height="0" PageSize="100"   x:Name="BIGvw_DluznicyAktualdds" QueryName="GetBIGvw_DluznicyAktualQuery" Width="0" LoadedData="GetBIG_ImportByDate_LoadedData" LoadingData="GetBIG_ImportByDate_LoadingData" >
            <telerik:RadDomainDataSource.DomainContext>
                <my:LexEnaMeritumDomainContext />
            </telerik:RadDomainDataSource.DomainContext>

        </telerik:RadDomainDataSource>



        <telerik:RadDomainDataSource AutoLoad="False" Height="0"  PageSize="400" x:Name="BIGvw_ImportyDetaildds" QueryName="GetBIGvw_ImportyDetailByCaseIdQuery" Width="0" LoadingData="BIGvw_ImportyDetaildds_LoadingData">
            <telerik:RadDomainDataSource.DomainContext>
                <my:LexEnaMeritumDomainContext />
            </telerik:RadDomainDataSource.DomainContext>
            <telerik:RadDomainDataSource.QueryParameters>

                <telerik:QueryParameter ParameterName="Import_Id" />


            </telerik:RadDomainDataSource.QueryParameters>
        </telerik:RadDomainDataSource>


        <telerik:RadDomainDataSource AutoLoad="False" Height="0"  PageSize="100" x:Name="BIGvw_ImportyDetailAktualdds"   QueryName="GetBIGvw_ObligationLastStatusByCaseIdQuery" Width="0" LoadingData="BIGvw_ImportyDetaildds_LoadingData">
            <telerik:RadDomainDataSource.DomainContext>
                <my:LexEnaMeritumDomainContext />
            </telerik:RadDomainDataSource.DomainContext>
            <telerik:RadDomainDataSource.QueryParameters>

                <telerik:QueryParameter ParameterName="Import_Id" />


            </telerik:RadDomainDataSource.QueryParameters>
        </telerik:RadDomainDataSource>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="249*" />
                <RowDefinition Height="28*" />
                <RowDefinition Height="260*" />
                <RowDefinition Height="29"/>
            </Grid.RowDefinitions>
            <Grid.Resources>
                <Style x:Key="SentRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}">
                    <Setter Property="Background" Value="#00ffff" />
                    <Setter Property="FontWeight" Value="Normal"/>
                </Style>
                <Style x:Key="QuedRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}">
                    <Setter Property="Background" Value="#33ccff" />

                </Style>
                <Style x:Key="PrecessingRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}">
                    <Setter Property="Background" Value="#0066ff" />
                </Style>
                <Style x:Key="SuccessRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}">
                    <Setter Property="Background" Value="#00cc00" />
                </Style>
                <Style x:Key="FailureRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}">
                    <Setter Property="Background" Value="#ff0000" />
                </Style>
                <Style x:Key="ErrorRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}">
                    <Setter Property="Background" Value="#ff5c33" />
                </Style>
                <Style x:Key="NormalRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}"/>

                <local:ImportBIGRowStatus x:Key="converter" />
                <local:ConditionalStyleSelector x:Key="selector"  ConditionConverter="{StaticResource converter}">
                    <local:ConditionalStyleSelector.Rules>
                        <local:ConditionalStyleRule Style="{StaticResource NormalRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>0</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource SentRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>1</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource QuedRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>3</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource PrecessingRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>4</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource SuccessRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>200</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource ErrorRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>199</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource FailureRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>-1</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                    </local:ConditionalStyleSelector.Rules>
                </local:ConditionalStyleSelector>


                <local:ImportBIGDetailRowStatus x:Key="converterDetail" />
                <local:ConditionalStyleSelector x:Key="selectorDetail"  ConditionConverter="{StaticResource converterDetail}">
                    <local:ConditionalStyleSelector.Rules>
                        <local:ConditionalStyleRule Style="{StaticResource NormalRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>0</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource SuccessRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>1</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource FailureRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>-1</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                    </local:ConditionalStyleSelector.Rules>
                </local:ConditionalStyleSelector>

            </Grid.Resources>



            <telerik:RadBusyIndicator x:Name="BusyIndicator" IsBusy="{Binding IsBusy, ElementName=BIGvw_DluznicyAktualdds}" Grid.Row="1" BusyContent="Przetwarzanie w toku...">
                <telerik:RadGridView ValidatesOnDataErrors="None"  IsSynchronizedWithCurrentItem="false"  Grid.Row="1" x:Name="SprawyGridView" AutoGenerateColumns="false" SelectionMode="Multiple"  ItemsSource="{Binding DataView, ElementName=BIGvw_DluznicyAktualdds}" AutoExpandGroups="True" CanUserFreezeColumns="False" RowIndicatorVisibility="Visible" SelectionChanged="SprawyGridView_SelectionChanged"  FilteringMode="FilterRow" EnableColumnVirtualization="False" CanUserReorderColumns="False" Filtered="SprawyGridView_Filtered">
                    <telerik:RadContextMenu.ContextMenu>
                        <telerik:RadContextMenu x:Name="GridContextMenu">
                            <telerik:RadMenuItem Header="Pokaż szczegóły" Click="DetailsItem_Click"  />
                            <telerik:RadMenuItem Header="Szukaj" Click="SearchItem_Click"  />
                        </telerik:RadContextMenu>
                    </telerik:RadContextMenu.ContextMenu>

                    <telerik:RadGridView.Columns>



                        <telerik:GridViewDataColumn x:Name="SystemColumn1" Header="System" DataMemberBinding="{Binding System}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="NameColumn1" Header="Nazwa/Nazwisko" DataMemberBinding="{Binding Name,Mode=TwoWay}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="FirstNameColumn1" Header="Imię" DataMemberBinding="{Binding Firstname,Mode=TwoWay}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="A1Column1" Header="Adres" DataMemberBinding="{Binding Address1L1, Mode=TwoWay}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="A2Column1" Header="Adres(2)" DataMemberBinding="{Binding Address1L2, Mode=TwoWay}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="CliNo1" Header="Nr Klienta" DataMemberBinding="{Binding NrKlienta, Mode=TwoWay}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="IdNumber1" Header="NIP/Pesel" DataMemberBinding="{Binding IDNumber, Mode=TwoWay}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="DataSuspend" Header="Data zawieszenia" DataMemberBinding="{Binding SuspendDate, StringFormat=\{0:yyyy-MM-dd\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DataNotify" Header="Data zawiadom." DataMemberBinding="{Binding NotifyDate, StringFormat=\{0:yyyy-MM-dd\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />

                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
            </telerik:RadBusyIndicator>

            <telerik:RadDataPager x:Name="RadDataPagerSprawy" Source="{Binding DataView, ElementName=BIGvw_DluznicyAktualdds}" Grid.Row="2" DisplayMode="All" IsTotalItemCountFixed="True" Margin="0,2,0,0" VerticalAlignment="Top" d:LayoutOverrides="Height"  HorizontalAlignment="Right" Width="307"/>

            <telerik:RadBusyIndicator x:Name="BusyIndicator2" IsBusy="{Binding IsBusy, ElementName=BIGvw_ImportyDetailAktualdds}"  Grid.Row="3" BusyContent="Odczyt danych proszę czekać...">
                <telerik:RadGridView ValidatesOnDataErrors="None"  RowStyleSelector="{StaticResource selectorDetail}" FilteringMode="FilterRow" IsReadOnly="True" IsSynchronizedWithCurrentItem="true" SelectionMode="Single"  Grid.Row="3" x:Name="ImportDetailsGridView" AutoGenerateColumns="false"  ItemsSource="{Binding DataView, ElementName=BIGvw_ImportyDetailAktualdds,Mode=TwoWay}" AutoExpandGroups="True" CanUserFreezeColumns="False" RowIndicatorVisibility="Visible" RowLoaded="ImportDetailsGridView_RowLoaded">

                    <telerik:RadGridView.Columns>
                        
                        <telerik:GridViewDataColumn x:Name="Lp" Header="Lp"  IsReadOnly="True" DataMemberBinding="{Binding Row}"  IsFilterable="false" HeaderTextAlignment="Center"  TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="TypOperacjiColumn" IsReadOnly="True" Header="Operacja" DataMemberBinding="{Binding TypOperacji}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="StatusO" IsReadOnly="True" Header="Status" DataMemberBinding="{Binding StatusOperacji}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="StatusOpois" IsReadOnly="True" Header="Status" DataMemberBinding="{Binding StatOpis}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="Nrfaktury" IsReadOnly="True" Header="Nr Faktury" DataMemberBinding="{Binding Title}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="DataWymag" IsReadOnly="True" Header="Data wymagalności" DataMemberBinding="{Binding DataWymag, StringFormat=\{0:yyyy-MM-dd\}, Mode=TwoWay}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="Saldo" Header="Należność(saldo)" DataMemberBinding="{Binding Saldo ,StringFormat=\{0:c2\},ConverterCulture=pl-PL }" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" ShowColumnWhenGrouped="False" />
                        <telerik:GridViewDataColumn x:Name="DataWysWezw" IsReadOnly="True" Header="Data wysłania wezw." DataMemberBinding="{Binding DataWysWezw, StringFormat=\{0:yyyy-MM-dd\}, Mode=TwoWay}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DataSuspend1" Header="Data zawieszenia" DataMemberBinding="{Binding SuspendDate, StringFormat=\{0:yyyy-MM-dd\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DataNotify1" Header="Data zawiadom." DataMemberBinding="{Binding NotifyDate, StringFormat=\{0:yyyy-MM-dd\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DataImpDet" IsReadOnly="True" Header="Data importu" DataMemberBinding="{Binding DataImportu, StringFormat=\{0:yyyy-MM-dd HH:mm\}}"  HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DataProcedowaniaKrd" IsReadOnly="True" Header="Data przetworzenia" DataMemberBinding="{Binding DataProcedowaniaKrd, StringFormat=\{0:yyyy-MM-dd HH:mm\}}"  HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />

                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
            </telerik:RadBusyIndicator>

            <telerik:RadDataPager x:Name="RadDataPagerImportDetails" Source="{Binding DataView, ElementName=BIGvw_ImportyDetailAktualdds}" Grid.Row="4" DisplayMode="All" IsTotalItemCountFixed="True" Margin="493,1,0,0" VerticalAlignment="Top" d:LayoutOverrides="Height"  HorizontalAlignment="Right" Width="307"/>
            <Button x:Name="btExport" Content="Eksport do XLS" HorizontalAlignment="Left" Margin="383,5,0,0" Grid.Row="2" VerticalAlignment="Top" Width="102" Click="btExport_Click"/>
           
            <StackPanel HorizontalAlignment="Left" Margin="500,2,0,0" Width="246" Orientation="Horizontal">
                <telerik:RadRadioButton x:Name="radRadioAktual"  Content="Dane aktualne" Height="Auto" Width="100" HorizontalAlignment="Left" IsChecked="True" Checked="radRadioAktual_Checked" />
                <telerik:RadRadioButton x:Name="radRadioPelne"    Content="Dane pełne" Height="Auto" Width="100" HorizontalAlignment="Right"  Checked="radRadioPelne_Checked" />
            </StackPanel>
            <Button x:Name="btDelImport" Content="Wykreśl" HorizontalAlignment="Left" Margin="6,1,0,0" VerticalAlignment="Top" Width="75" Click="btDelImport_Click" />
            <Button x:Name="btUpdate"  Content="Aktualizuj" HorizontalAlignment="Left" Margin="88,4,0,0" Grid.Row="2" VerticalAlignment="Top" Width="75" Click="btUpdate_Click"/>
            <Button x:Name="btSuspend"   Content="Zawieś" HorizontalAlignment="Left" Margin="166,4,0,0" Grid.Row="2" VerticalAlignment="Top" Width="75" Click="btSuspend_Click"/>
            <Button x:Name="btResume"   Content="Podejmij" HorizontalAlignment="Left" Margin="242,4,0,0" Grid.Row="2" VerticalAlignment="Top" Width="75" Click="buResume_Click"/>
            <Button x:Name="btDeleteOblig"   Content="Wykreśl nal." HorizontalAlignment="Left" Margin="8,4,0,0" Grid.Row="2" VerticalAlignment="Top" Width="75" Click="btDeleteOblig_Click"/>
            <Button x:Name="btUpdateDebtor"   Content="Aktualizuj" HorizontalAlignment="Left" Margin="84,2,0,0" VerticalAlignment="Top" Width="75" Click="btUpdateDebtor_Click"/>
            <Button x:Name="btSuspendDebtor"   Content="Zawieś" HorizontalAlignment="Left" Margin="162,2,0,0" VerticalAlignment="Top" Width="75" Click="btSuspendDebtor_Click"/>
            <Button x:Name="btResumeDebtor"   Content="Podejmij" HorizontalAlignment="Left" Margin="240,2,0,0" VerticalAlignment="Top" Width="75" Click="btResumeDebtor_Click" />
            <Button x:Name="btNotify" Content="Powiadom" HorizontalAlignment="Left" Margin="318,2,0,0" VerticalAlignment="Top" Width="75" Click="btNotify_Click"/>
            <Button x:Name="btDelAll" Content="Wykreśl wszyst." HorizontalAlignment="Left" Visibility="Collapsed" Margin="400,1,0,0" VerticalAlignment="Top" Width="75" Click="btDelAll_Click"  />

        </Grid >
    </Grid>
</UserControl>
