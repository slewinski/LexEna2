<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:riaControls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls.DomainServices" xmlns:my="clr-namespace:LexEnaTrs.Web" xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation" x:Class="LexEnaTrs.Views.ImportBilling"
    mc:Ignorable="d"
    xmlns:local="clr-namespace:LexEnaTrs" 
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:DesignHeight="592" Width="Auto" Loaded="UserControl_Loaded">

    <Grid x:Name="LayoutRoot" Background="White">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
                <RowDefinition />
                <RowDefinition Height="29"/>
            </Grid.RowDefinitions>





            <telerik:RadBusyIndicator x:Name="BusyIndicator"  Grid.Row="2" BusyContent="Przetwarzanie w toku..." d:LayoutOverrides="LeftMargin, RightMargin, TopMargin, BottomMargin">
                <telerik:RadGridView ValidatesOnDataErrors="None"   IsSynchronizedWithCurrentItem="false"  Grid.Row="1" x:Name="SprawyGridView" AutoGenerateColumns="false" SelectionMode="Single"   CanUserFreezeColumns="False" RowIndicatorVisibility="Collapsed"  EnableColumnVirtualization="False" CanUserReorderColumns="False" Filtered="SprawyGridView_Filtered" ShowGroupPanel="False" EnableRowVirtualization="False" CanUserSortGroups="False" EnableColumnGroupsVirtualization="False" CellEditEnded="SprawyGridView_CellEditEnded">
                    <telerik:RadGridView.ChildTableDefinitions>

                        <telerik:GridViewTableDefinition>
                            <telerik:GridViewTableDefinition.Relation>
                                <telerik:PropertyRelation ParentPropertyName="Odbiorca.Obciazenia" />
                            </telerik:GridViewTableDefinition.Relation>
                        </telerik:GridViewTableDefinition>

                    </telerik:RadGridView.ChildTableDefinitions>
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewDataColumn x:Name="Lp" Header="Lp." DataMemberBinding="{Binding id}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="message" Header="Info" DataMemberBinding="{Binding message}" HeaderTextAlignment="Center" MinWidth="30" TextAlignment="Left" Width="120"  />
                        <telerik:GridViewCheckBoxColumn x:Name="czy_ok" Header="Wykonane?"  DataMemberBinding="{Binding czy_ok}"  HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" EditTriggers="None" IsReadOnly="True" />
                        <telerik:GridViewCheckBoxColumn x:Name="czyrej" Header="Wpisać ?" AutoSelectOnEdit="True" DataMemberBinding="{Binding czyrej, Mode=TwoWay}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" EditTriggers="CellClick" />
                        <telerik:GridViewComboBoxColumn  EditTriggers="CellClick"  Header="Odsetki" MaxWidth="250" DataMemberBinding="{Binding CzyUstawowe, Mode=TwoWay}" UniqueName="CzyUstawowe" IsFilterable="false"  HeaderTextAlignment="Center" TextAlignment="Center"  
                                SelectedValueMemberPath="Numer" 
                                DisplayMemberPath="Nazwa"
                        />
                        <telerik:GridViewDataColumn x:Name="Numer" UniqueName="NumerSpr" Header="Numer sprawy" DataMemberBinding="{Binding nr, Mode=TwoWay}" HeaderTextAlignment="Center" MinWidth="15"   TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="Sygnatura" Header="Sygnatura" DataMemberBinding="{Binding sygn_obciaz, Mode=TwoWay}" HeaderTextAlignment="Center" MinWidth="15"  TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="NrEwidencyjny" Header="Nr. Ewidencyjny" DataMemberBinding="{Binding Odbiorca.Nr_ewidencyjny}" HeaderTextAlignment="Center" MinWidth="40" IsReadOnly="True"   TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="Nazwa" Header="Nazwa" DataMemberBinding="{Binding Odbiorca.Nazwa}" HeaderTextAlignment="Center" MinWidth="40" IsReadOnly="True"   TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="Pesel" Header="Pesel" DataMemberBinding="{Binding Odbiorca.PESEL}" HeaderTextAlignment="Center" MinWidth="20" IsReadOnly="True"   TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="NIP" Header="NIP" DataMemberBinding="{Binding Odbiorca.NIP}" HeaderTextAlignment="Center" MinWidth="20" IsReadOnly="True"   TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="KRS" Header="KRS" DataMemberBinding="{Binding Odbiorca.KRS}" HeaderTextAlignment="Center" MinWidth="20" IsReadOnly="True"   TextAlignment="Left" />


                    </telerik:RadGridView.Columns>

                </telerik:RadGridView>
            </telerik:RadBusyIndicator>

            <telerik:RadDatePicker x:Name="rdpData"  HorizontalAlignment="Left" Culture="pl-PL" Height="23" Margin="122,13,0,14" Width="120"/>
            <sdk:Label x:Name="label" HorizontalAlignment="Left" Height="24" Margin="10,14,0,0" Width="120" Content="Data księgowania" VerticalAlignment="Top"/>
            <sdk:Label x:Name="label1" HorizontalAlignment="Left" Height="28" Margin="259,9,0,13" Width="120" Content="Dokument księgowy"/>
            <telerik:RadComboBox  x:Name="cbTypDok"  SelectedValue="{Binding TypDok, Mode=TwoWay}"  ItemsSource="{Binding typOznaczeniaDowodowWiena, Source={StaticResource SlownikDowodowWiena}}"  SelectedValuePath="Nazwa" DisplayMemberPath="Nazwa" HorizontalAlignment="Left" Margin="386,0,0,17" Width="120" VerticalAlignment="Bottom" Height="19"/>
            <telerik:RadButton x:Name="btImport" Content="Importuj zbiór..." HorizontalAlignment="Left" Margin="668,13,0,15" Grid.Row="1" Width="105" Click="btImport_Click_1"  />
            <sdk:Label x:Name="label2" HorizontalAlignment="Left" Height="28" Margin="3,9,0,13" Grid.Row="1" Width="166" Content="Oznaczenie pierwszej sprawy"/>
            <telerik:RadComboBox  x:Name="cbOddzial" FontSize="9"  SelectedValue="{Binding Oddzial, Mode=TwoWay}"  ItemsSource="{Binding typOddzialyWiena, Source={StaticResource SlownikSlownikOddzialowWiena}}"  SelectedValuePath="Numer" DisplayMemberPath="Nazwa" Margin="174,12,0,16" Grid.Row="1" HorizontalAlignment="Left" Width="234" SelectionChanged="cbOddzial_SelectionChanged"/>
            <telerik:RadComboBox x:Name="cbRepertorium"  SelectedValue="{Binding Symbol, Mode=TwoWay}"  ItemsSource="{Binding typSymboleSprawWiena, Source={StaticResource SlownikSymboliSprawWiena}}"  SelectedValuePath="Numer" DisplayMemberPath="Nazwa" HorizontalAlignment="Left" Margin="413,12,0,16" Grid.Row="1" Width="78" SelectionChanged="cbRepertorium_SelectionChanged"  />
            <TextBox x:Name="tbNumer" Margin="502,12,0,15" Grid.Row="1" TextWrapping="Wrap" Text="" HorizontalAlignment="Left" Width="70"/>
            <sdk:Label x:Name="label3" Height="17" FontSize="14" Margin="584,0,0,20" Grid.Row="1" VerticalAlignment="Bottom" Content="/" HorizontalAlignment="Left" Width="14"/>
            <telerik:RadButton x:Name="btNumeruj" Content="Numeruj" Visibility="Collapsed" Margin="770,17,0,12" Grid.Row="0" HorizontalAlignment="Left" Width="64" Click="btNumeruj_Click" />
            <telerik:RadButton x:Name="btZapisz" Content="Zapisz" Margin="856,13,-20,15" Grid.Row="1" HorizontalAlignment="Left" Width="60" Click="btZapisz_Click" />
            <telerik:RadNumericUpDown x:Name="numRok" HorizontalAlignment="Left" Margin="600,13,0,0" Grid.Row="1" VerticalAlignment="Top" NumberDecimalDigits="4" NumberDecimalSeparator="" Width="54" Height="22"  IsInteger="True" IsEditable="False" Maximum="2040" Minimum="2010" ValueChanged="numRok_ValueChanged" />
            <telerik:RadButton x:Name="btNew" Content="Nowy import" HorizontalAlignment="Left" Margin="856,17,-20,0" VerticalAlignment="Top" Width="89" Height="22" Click="btNew_Click"/>
            <sdk:Label x:Name="labelKancelaria" HorizontalAlignment="Left" Height="28" Content="Kancelaria" VerticalAlignment="Center" Width="59" Grid.Row="0" Margin="524,9,0,13"/>
            <telerik:RadComboBox  x:Name="cbRadca" FontSize="9"  SelectedValue="{Binding Kancelaria, Mode=TwoWay}"  ItemsSource="{Binding typKancelarieWiena,  Source={StaticResource KonfiguracjaWiena}}"   SelectedValuePath="Numer" DisplayMemberPath="Nazwa" Margin="590,13,0,15" Grid.Row="0"  HorizontalAlignment="Left" Width="150" VerticalAlignment="Center" Height="19" />




        </Grid >

    </Grid>
</UserControl>