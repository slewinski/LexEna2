<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:riaControls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls.DomainServices" xmlns:my="clr-namespace:LexEnaTrs.Web" xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation" x:Class="LexEnaTrs.Views.KrdOperacje"
    mc:Ignorable="d"
    xmlns:local="clr-namespace:LexEnaTrs" 
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:DesignHeight="592" d:DesignWidth="800" Loaded="UserControl_Loaded">

    <Grid x:Name="LayoutRoot" Background="White">

       
        <telerik:RadDomainDataSource AutoLoad="False" Height="0"  PageSize="400" x:Name="BIGvw_ImportyDetaildds" QueryName="GetBIGvw_ImportyDetailQuery" Width="0" >
            <telerik:RadDomainDataSource.DomainContext>
                <my:LexEnaMeritumDomainContext />
            </telerik:RadDomainDataSource.DomainContext>
          
        </telerik:RadDomainDataSource>

        <telerik:RadDomainDataSource AutoLoad="False" Height="0"  PageSize="400" x:Name="BIGvw_ImportyDetailAktualdds" QueryName="GetBIGvw_ObligationLastStatusQuery" Width="0" >
            <telerik:RadDomainDataSource.DomainContext>
                <my:LexEnaMeritumDomainContext />
            </telerik:RadDomainDataSource.DomainContext>

        </telerik:RadDomainDataSource>



            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="260*" />
                <RowDefinition Height="29"/>
            </Grid.RowDefinitions>
            <Grid.Resources>
                <Style x:Key="SentRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}">
                    <Setter Property="Background" Value="#00ffff" />
                    <Setter Property="FontWeight" Value="Normal"/>
                </Style>
                <Style x:Key="QuedRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}">
                    <Setter Property="Background" Value="#33ccff" />

                </Style>
                <Style x:Key="PrecessingRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}">
                    <Setter Property="Background" Value="#0066ff" />
                </Style>
                <Style x:Key="SuccessRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}">
                    <Setter Property="Background" Value="#00cc00" />
                </Style>
                <Style x:Key="FailureRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}">
                    <Setter Property="Background" Value="#ff0000" />
                </Style>
                <Style x:Key="ErrorRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}">
                    <Setter Property="Background" Value="#ff5c33" />
                </Style>
                <Style x:Key="NormalRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}"/>

                <local:ImportBIGRowStatus x:Key="converter" />
                <local:ConditionalStyleSelector x:Key="selector"  ConditionConverter="{StaticResource converter}">
                    <local:ConditionalStyleSelector.Rules>
                        <local:ConditionalStyleRule Style="{StaticResource NormalRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>0</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource SentRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>1</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource QuedRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>3</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource PrecessingRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>4</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource SuccessRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>200</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource ErrorRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>199</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource FailureRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>-1</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                    </local:ConditionalStyleSelector.Rules>
                </local:ConditionalStyleSelector>


                <local:ImportBIGDetailRowStatus x:Key="converterDetail" />
                <local:ConditionalStyleSelector x:Key="selectorDetail"  ConditionConverter="{StaticResource converterDetail}">
                    <local:ConditionalStyleSelector.Rules>
                        <local:ConditionalStyleRule Style="{StaticResource NormalRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>0</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource SuccessRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>1</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource FailureRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>-1</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                    </local:ConditionalStyleSelector.Rules>
                </local:ConditionalStyleSelector>

            </Grid.Resources>




            <telerik:RadBusyIndicator x:Name="BusyIndicator" IsBusy="{Binding IsBusy, ElementName=BIGvw_ImportyDetailAktualdds}" Grid.Row="1" BusyContent="Odczyt danych proszę czekać...">
                <telerik:RadGridView ValidatesOnDataErrors="None" RowStyleSelector="{StaticResource selectorDetail}" FilteringMode="FilterRow" IsSynchronizedWithCurrentItem="false"  Grid.Row="1" x:Name="ImportDetailsGridView" AutoGenerateColumns="false" SelectionMode="Multiple" IsReadOnly="True" ItemsSource="{Binding DataView, ElementName=BIGvw_ImportyDetailAktualdds}" AutoExpandGroups="True" CanUserFreezeColumns="False" RowIndicatorVisibility="Visible" Filtered="ImportDetailsGridView_Filtered" >

                    <telerik:RadGridView.Columns>

                        <telerik:GridViewDataColumn x:Name="Lp" Header="Lp"  IsReadOnly="True" DataMemberBinding="{Binding Row}"  IsFilterable="false" HeaderTextAlignment="Center"  TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="TypOperacjiColumn" Header="Operacja" DataMemberBinding="{Binding TypOperacji}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="StatusO" Header="Status" DataMemberBinding="{Binding StatusOperacji}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="StatusOpois" Header="Status" DataMemberBinding="{Binding StatOpis}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="SystemColumn" Header="System" DataMemberBinding="{Binding System}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="NameColumn" Header="Nazwa/Nazwisko" DataMemberBinding="{Binding Name}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="FirstNameColumn" Header="Imię" DataMemberBinding="{Binding Firstname}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="A1Column" Header="Adres" DataMemberBinding="{Binding Address1L1}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="A2Column" Header="Adres(2)" DataMemberBinding="{Binding Address1L2}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="CliNo" Header="Nr Klienta" DataMemberBinding="{Binding NrKlienta}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="IdNumber" Header="NIP/Pesel" DataMemberBinding="{Binding IDNumber}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="Nrfaktury" Header="Nr Faktury" DataMemberBinding="{Binding Title}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="DataWymag" Header="Data wymagalności" DataMemberBinding="{Binding DataWymag, StringFormat=\{0:yyyy-MM-dd\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn Header="Należnośc" DataMemberBinding="{Binding Saldo ,StringFormat=\{0:c2\},ConverterCulture=pl-PL }" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DataImpDet" Header="Data importu" DataMemberBinding="{Binding DataImportu, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DataSuspend" Header="Data zawieszenia" DataMemberBinding="{Binding SuspendDate, StringFormat=\{0:yyyy-MM-dd\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DataNotify" Header="Data zawiadom." DataMemberBinding="{Binding NotifyDate, StringFormat=\{0:yyyy-MM-dd\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DataProcedowaniaKrd" Header="Data przetworzenia" DataMemberBinding="{Binding DataProcedowaniaKrd, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />

                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
            </telerik:RadBusyIndicator>

            <telerik:RadDataPager x:Name="RadDataPagerImportDetails" Source="{Binding DataView, ElementName=BIGvw_ImportyDetailAktualdds}" Grid.Row="2" DisplayMode="All" IsTotalItemCountFixed="True" Margin="493,1,0,0" VerticalAlignment="Top" d:LayoutOverrides="Height"  HorizontalAlignment="Right" Width="307"/>
            <StackPanel HorizontalAlignment="Left" Margin="10,2,0,0" Width="246" Orientation="Horizontal">
                <telerik:RadRadioButton x:Name="radRadioAktual"  Content="Dane aktualne" Height="Auto" Width="100" HorizontalAlignment="Left" IsChecked="True" Checked="radRadioAktual_Checked" />
                <telerik:RadRadioButton x:Name="radRadioPelne"    Content="Dane pełne" Height="Auto" Width="100" HorizontalAlignment="Right"  Checked="radRadioPelne_Checked" />
            </StackPanel>

        </Grid >
    </Grid>
</UserControl>
