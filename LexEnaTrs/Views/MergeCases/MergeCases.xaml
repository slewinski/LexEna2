<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:riaControls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls.DomainServices" xmlns:my="clr-namespace:LexEnaTrs.Web" xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation" x:Class="LexEnaTrs.Views.MergeCases"
    mc:Ignorable="d"
    xmlns:local="clr-namespace:LexEnaTrs" 
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:DesignHeight="592" Width="Auto">

    <Grid x:Name="LayoutRoot" Background="White">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="66"/>
                <RowDefinition Height="34"/>
                <RowDefinition />
                <RowDefinition Height="29"/>
            </Grid.RowDefinitions>





            <telerik:RadBusyIndicator x:Name="BusyIndicator"  Grid.Row="2" BusyContent="Przetwarzanie w toku...">
                <telerik:RadGridView ValidatesOnDataErrors="None"   IsSynchronizedWithCurrentItem="false"  Grid.Row="1" x:Name="SprawyGridView" AutoGenerateColumns="false" SelectionMode="Single"   CanUserFreezeColumns="False" RowIndicatorVisibility="Collapsed"  EnableColumnVirtualization="False" CanUserReorderColumns="False"  ShowGroupPanel="False" EnableRowVirtualization="False" CanUserSortGroups="False" EnableColumnGroupsVirtualization="False" >
                    <telerik:RadGridView.ChildTableDefinitions>

                        <telerik:GridViewTableDefinition>
                            <telerik:GridViewTableDefinition.Relation>
                                <telerik:PropertyRelation ParentPropertyName="Odbiorca.Obciazenia" />
                            </telerik:GridViewTableDefinition.Relation>
                        </telerik:GridViewTableDefinition>

                    </telerik:RadGridView.ChildTableDefinitions>
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewDataColumn x:Name="Lp" Header="Lp." DataMemberBinding="{Binding id}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="message" Header="Info" DataMemberBinding="{Binding message}" HeaderTextAlignment="Center" MinWidth="30" TextAlignment="Left" Width="120"  />
                        <telerik:GridViewCheckBoxColumn x:Name="czy_ok" Header="Wykonane?"  DataMemberBinding="{Binding czy_ok}"  HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" EditTriggers="None" IsReadOnly="True" />
                        <telerik:GridViewCheckBoxColumn x:Name="czyrej" Header="Wpisać ?" AutoSelectOnEdit="True" DataMemberBinding="{Binding czyrej, Mode=TwoWay}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" EditTriggers="CellClick" />
                        <telerik:GridViewDataColumn x:Name="Numer" UniqueName="NumerSpr" Header="Numer sprawy" DataMemberBinding="{Binding nr, Mode=TwoWay}" HeaderTextAlignment="Center" MinWidth="15"   TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="Sygnatura" Header="Sygnatura" DataMemberBinding="{Binding sygn_obciaz, Mode=TwoWay}" HeaderTextAlignment="Center" MinWidth="15"  TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="NrEwidencyjny" Header="Nr. Ewidencyjny" DataMemberBinding="{Binding Odbiorca.Nr_ewidencyjny}" HeaderTextAlignment="Center" MinWidth="40" IsReadOnly="True"   TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="Nazwa" Header="Nazwa" DataMemberBinding="{Binding Odbiorca.Nazwa}" HeaderTextAlignment="Center" MinWidth="40" IsReadOnly="True"   TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="Pesel" Header="Pesel" DataMemberBinding="{Binding Odbiorca.PESEL}" HeaderTextAlignment="Center" MinWidth="20" IsReadOnly="True"   TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="NIP" Header="NIP" DataMemberBinding="{Binding Odbiorca.NIP}" HeaderTextAlignment="Center" MinWidth="20" IsReadOnly="True"   TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="KRS" Header="KRS" DataMemberBinding="{Binding Odbiorca.KRS}" HeaderTextAlignment="Center" MinWidth="20" IsReadOnly="True"   TextAlignment="Left" />


                    </telerik:RadGridView.Columns>

                </telerik:RadGridView>
            </telerik:RadBusyIndicator>


            <sdk:Label x:Name="label" HorizontalAlignment="Left" Height="24" Margin="10,16,0,0" Width="49" Content="Sprawę:" VerticalAlignment="Top"/>
            <TextBox x:Name="tbSygnSrc" HorizontalAlignment="Left" Height="23" Margin="64,14,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="120"/>
            <sdk:Label x:Name="label1" HorizontalAlignment="Left" Margin="189,16,0,0" Width="103" Content="Dołącz do sprawy: "  VerticalAlignment="Top"/>
            <TextBox x:Name="tbSygnDest" HorizontalAlignment="Left" Height="23" Margin="297,14,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="120"/>
            <telerik:RadButton x:Name="btMerge" Content="Połącz sprawy" HorizontalAlignment="Left" Margin="431,14,0,29" Grid.Row="0" Width="105"  RenderTransformOrigin="0.632,-1.524" Click="btMerge_Click"  />
            <sdk:Label x:Name="label2" HorizontalAlignment="Left" Height="14" Margin="60,42,0,0" Content="Wprowadź pełną sygnaturę sprawy" HorizontalContentAlignment="Center" VerticalAlignment="Top" Width="131" FontSize="7" FontStyle="Italic"/>
            <sdk:Label x:Name="label3" HorizontalAlignment="Left" Height="14" Margin="300,42,0,0" Content="Wprowadź pełną sygnaturę sprawy" HorizontalContentAlignment="Center" VerticalAlignment="Top" Width="131" FontSize="7" FontStyle="Italic"/>




        </Grid >

    </Grid>
</UserControl>