<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:riaControls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls.DomainServices" xmlns:my="clr-namespace:LexEnaTrs.Web" xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation" x:Class="LexEnaTrs.Views.ListaSprawById"
    mc:Ignorable="d"
    d:DesignHeight="592" d:DesignWidth="800" Loaded="UserControl_Loaded">
    
    <Grid x:Name="LayoutRoot" Background="White">
        
           
        <Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="26"/>
				<RowDefinition/>
				
			</Grid.RowDefinitions>

<telerik:RadDomainDataSource AutoLoad="False" Height="0" PageSize="30"  x:Name="ListaSprawSearch" QueryName="GetSearchSprQuery" Width="0"  >
                <telerik:RadDomainDataSource.DomainContext>
                    <my:LexEnaMeritumDomainContext />
                </telerik:RadDomainDataSource.DomainContext>
                <telerik:RadDomainDataSource.QueryParameters>
                     
                    <telerik:QueryParameter ParameterName="Sygnatura" />
                    <telerik:QueryParameter ParameterName="Nazwa" />
                    <telerik:QueryParameter ParameterName="SygnNCe" />
                    <telerik:QueryParameter ParameterName="NrEwid" />
                    <telerik:QueryParameter ParameterName="Opis" />
                    <telerik:QueryParameter ParameterName="Ulica" />
                    <telerik:QueryParameter ParameterName="Miejscowosc" />
                    <telerik:QueryParameter ParameterName="Poczta" />
                    <telerik:QueryParameter ParameterName="Pesel" />
                </telerik:RadDomainDataSource.QueryParameters>
            </telerik:RadDomainDataSource>
            
            <telerik:RadDataPager x:Name="RadDataPagerSprawy" Source="{Binding DataView, ElementName=ListaSprawSearch}" IsEnabled="False" DisplayMode="Text"  IsTotalItemCountFixed="True" Margin="6,-1,0,0" VerticalAlignment="Top" d:LayoutOverrides="Height"  HorizontalAlignment="Left" Width="145" PageIndexChanged="RadDataPagerSprawy_PageIndexChanged" Height="25" />
            
		  <Button x:Name="OpenSpr" Content="Otwórz sprawę" HorizontalAlignment="Left" Margin="157,-1,0,0" Width="116" VerticalAlignment="Top" Click="OpenSpr_Click"/>
            <telerik:RadBusyIndicator x:Name="BusyIndicator" IsBusy="{Binding IsBusy, ElementName=SprawyGridView}" Grid.Row="1" BusyContent="Przetwarzanie w toku..." Margin="0,4,0,0">
                <telerik:RadGridView ValidatesOnDataErrors="None" IsSynchronizedWithCurrentItem="false"  Grid.Row="1" x:Name="SprawyGridView" AutoGenerateColumns="false" SelectionMode="Multiple"  IsReadOnly="True" Grid.RowSpan="2"  AutoExpandGroups="True" CanUserFreezeColumns="False" RowIndicatorVisibility="Visible" SelectionChanged="SprawyGridView_SelectionChanged">
               
                <telerik:RadGridView.Columns>
                    <telerik:GridViewSelectColumn UniqueName="CurrentSprawa" />
                    <telerik:GridViewDataColumn x:Name="SygnaturaColumn" Header="Sygnatura" DataMemberBinding="{Binding sygnatura}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                       
                    <telerik:GridViewDataColumn Header="Dłużnik" DataMemberBinding="{Binding Dluznik}" Width="*" HeaderTextAlignment="Center" MinWidth="150" TextAlignment="Left" />
                    <telerik:GridViewDataColumn Header="Status Sprawy" DataMemberBinding="{Binding Nazwa}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                    <telerik:GridViewDataColumn Header="Oddział" DataMemberBinding="{Binding Oddzial}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
               
                    <telerik:GridViewDataColumn Header="Nr ewid." DataMemberBinding="{Binding NrEwid}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                     
                    <telerik:GridViewDataColumn Header="Jednostka" DataMemberBinding="{Binding Nazwa_Jednostki}" IsReadOnly="True" IsFilterable="false" HeaderTextAlignment="Center" MinWidth="5" TextAlignment="Center" />
                        <telerik:GridViewDataColumn Header="Data statusu" DataMemberBinding="{Binding DataStatusu, StringFormat=\{0:d\}}"  DataFormatString=" {0:yyyy-MM-dd} " IsReadOnly="True" IsFilterable="false" HeaderTextAlignment="Center" MinWidth="5" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="OstDok" Header="Ost. dok." DataMemberBinding="{Binding OstatniDok}" IsReadOnly="True" IsFilterable="false"  HeaderTextAlignment="Center" MinWidth="20" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DataOstDok" Header="Data ost. dok." DataMemberBinding="{Binding OstatniDataDok, StringFormat=\{0:d\}}"  DataFormatString=" {0:yyyy-MM-dd} "  IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="StatOstDok" Header="Ost. dok. status" DataMemberBinding="{Binding OstatniStatusDok, Converter={StaticResource StatusDocConverter}}"  IsReadOnly="True" IsFilterable="false" HeaderTextAlignment="Center" MinWidth="20" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="Referent" Header="Referent" DataMemberBinding="{Binding Uzytkownik_Nazwa }"  IsReadOnly="True" IsFilterable="false" HeaderTextAlignment="Center" MinWidth="20" TextAlignment="Center" />
                        <telerik:GridViewDataColumn Header="Data dekretacji" DataMemberBinding="{Binding DataDekretJednostka, StringFormat=\{0:d\}}"  DataFormatString=" {0:yyyy-MM-dd} "  IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="5" TextAlignment="Center" />

                    </telerik:RadGridView.Columns>               
                </telerik:RadGridView>
            </telerik:RadBusyIndicator>

           
        </Grid >
    </Grid>
</UserControl>
