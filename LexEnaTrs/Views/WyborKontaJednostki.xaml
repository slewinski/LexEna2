<controls:ChildWindow x:Class="LexEnaTrs.Views.WyborKontaJednostki"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
           xmlns:controls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls"
           xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
           Width="400" Height="300" 
           Title="Wybor Konta EPU">
    <Grid x:Name="LayoutRoot" Margin="2">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <telerik:RadGridView x:Name="GridViewSelKontoEPU" RowIndicatorVisibility="Collapsed" IsReadOnly="True"  AutoGenerateColumns="False" ItemsSource="{Binding dictionaryKontaEPU, Source={StaticResource ListaKontEPU}}"  ShowColumnHeaders="False" ShowGroupPanel="False"  Loaded="GridViewSelKontoEPU_Loaded">
            <telerik:RadGridView.Columns>
                <telerik:GridViewDataColumn Header="Pełnomocnik" DataMemberBinding="{Binding NazwaKonta}" Width="*" />
                <!--<telerik:GridViewDataColumn DataMemberBinding="(Binding Id}" />-->
            </telerik:RadGridView.Columns>
        </telerik:RadGridView>
        <Button x:Name="CancelButton" Content="Anuluj" Click="CancelButton_Click" Width="75" Height="23" HorizontalAlignment="Right" Margin="0,12,0,0" Grid.Row="1" />
        <Button x:Name="OKButton" Content="OK" Click="OKButton_Click" Width="75" Height="23" HorizontalAlignment="Right" Margin="0,12,79,0" Grid.Row="1" />
    </Grid>
</controls:ChildWindow>