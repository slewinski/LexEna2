            <Button x:Name="btImport"  Content="Importuj zbiór" HorizontalAlignment="Left" Margin="242,0,0,0"  Width="100" VerticalAlignment="Top" Click="btImport_Click"/>
            <Button x:Name="SendToKrd" Content="Zestawienie" HorizontalAlignment="Left" Margin="450,0,0,0" VerticalAlignment="Top" Width="100" Click="SendToKrd_Click" />
            <Button x:Name="Refresh" Content="Odśwież" HorizontalAlignment="Left" Margin="554,0,0,0" VerticalAlignment="Top" Width="100" Click="Refresh_Click"  />
            <Button x:Name="PrzeliczOdsetki" Content="Przelicz odsetki" HorizontalAlignment="Left" Margin="658,0,0,0" VerticalAlignment="Top" Width="100" Click="PrzeliczOdsetki_Click"  />
            <Button x:Name="DodajZlecenia" Content="Zlecenia księgowe" HorizontalAlignment="Left" Margin="762,0,0,0" VerticalAlignment="Top" Width="100" Click="DodajZlecenia_Click"   />

