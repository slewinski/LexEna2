                        <telerik:GridViewDataColumn x:Name="NalGlownaKsiegowaPrzedaw" Header="Nal gł. przedawniona " DataMemberBinding="{Binding NalGlownaKsiegowaPrzedaw , StringFormat=\{0:n2\}}"   HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Right" />
                        <telerik:GridViewDataColumn x:Name="KosztyKsiegowaPrzedaw" Header="Koszty przedawnione" DataMemberBinding="{Binding KosztyKsiegowaPrzedaw , StringFormat=\{0:n2\}}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Right" />
                        <telerik:GridViewDataColumn x:Name="NalGlownaKsiegowaNiePrzedaw" Header="Nal gł. Nieprzedawniona " DataMemberBinding="{Binding NalGlownaKsiegowaNiePrzedaw , StringFormat=\{0:n2\}}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Right" />
                        <telerik:GridViewDataColumn x:Name="KosztyKsiegowaNiePrzedaw" Header="Koszty Nieprzedawnione" DataMemberBinding="{Binding KosztyKsiegowaNiePrzedaw , StringFormat=\{0:n2\}}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Right" />
                        <telerik:GridViewDataColumn x:Name="DatPrzedawNal" Header="Data przedawnienia nal.gł." DataMemberBinding="{Binding DataPrzedawnieniaNalGl, StringFormat=\{0:yyyy-MM-dd\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DatPrzedawKoszty" Header="Data przedawnienia kosztów" DataMemberBinding="{Binding DataPrzedawnieniaKosztow, StringFormat=\{0:yyyy-MM-dd\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="StatusO" Header="Status" DataMemberBinding="{Binding Status}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="StatusOpis" Header="Status" DataMemberBinding="{Binding StatusText}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
