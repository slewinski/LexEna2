                        <telerik:GridViewDataColumn x:Name="Konto" Header="Konto"  Width="*" IsReadOnly="True"  DataMemberBinding="{Binding Nazwa}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Left" IsFilterable="False" ShowDistinctFilters="False" ShowFieldFilters="False" ShowFilterButton="False" />
                        <telerik:GridViewCheckBoxColumn   IsThreeState="False"
                                                    ShowDistinctFilters="False"
                                                    AutoSelectOnEdit="True"
                                                    EditTriggers="CellClick"
                       DataMemberBinding="{Binding Filter3, Converter={StaticResource IntToBoolConverter}, Mode=TwoWay }" 
                      HeaderTextAlignment="Center" TextAlignment="Left"  Width="50" IsFilterable="False" ShowFieldFilters="False" ShowFilterButton="False" >
                            <telerik:GridViewCheckBoxColumn.Header>
                                <StackPanel>
                                <CheckBox Click="KontaHeaderCheckBox_Click"  IsChecked="False"  IsThreeState="False" />
                               
                                </StackPanel>
                            </telerik:GridViewCheckBoxColumn.Header>

                        </telerik:GridViewCheckBoxColumn>


                    </telerik:RadGridView.Columns>


                </telerik:RadGridView>

                <!--
                <telerik:RadGridView Grid.Column="1" Grid.Row="0" ValidatesOnDataErrors="None"   IsSynchronizedWithCurrentItem="false"   x:Name="StatusyGrid" AutoGenerateColumns="false" SelectionMode="Single"   CanUserFreezeColumns="False" RowIndicatorVisibility="Collapsed"  EnableColumnVirtualization="False" CanUserReorderColumns="False"  ShowGroupPanel="False" EnableRowVirtualization="False" CanUserSortGroups="False" EnableColumnGroupsVirtualization="False" >
