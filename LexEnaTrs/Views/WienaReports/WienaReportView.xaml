                </telerik:RadGridView>
                <TextBox Text="0"  x:Name="tbCounter" Grid.Column="1" Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Canvas.ZIndex="1" ></TextBox>
