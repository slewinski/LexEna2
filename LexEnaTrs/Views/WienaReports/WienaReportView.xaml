                <telerik:RadGridView Grid.Column="0" Grid.Row="0" ValidatesOnDataErrors="None" ItemsSource="{Binding typOddzialyWiena,  Source={StaticResource KonfiguracjaWiena}}"  IsSynchronizedWithCurrentItem="false"   x:Name="OddzialyGrid" AutoGenerateColumns="false" SelectionMode="Single"   CanUserFreezeColumns="False" RowIndicatorVisibility="Collapsed"  EnableColumnVirtualization="False" CanUserReorderColumns="False"  ShowGroupPanel="False" EnableRowVirtualization="False" CanUserSortGroups="False"  EnableColumnGroupsVirtualization="False" IsFilteringAllowed="False" >

                    <telerik:RadGridView.Columns>
                        <telerik:GridViewDataColumn x:Name="Oddzial" Header="Oddział"  Width="*" IsReadOnly="True"  DataMemberBinding="{Binding Nazwa}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Left" IsFilterable="False" ShowDistinctFilters="False" ShowFieldFilters="False" ShowFilterButton="False" />
                        <telerik:GridViewCheckBoxColumn   IsThreeState="False"
                                                    ShowDistinctFilters="False"
                                                    AutoSelectOnEdit="True"
                                                    EditTriggers="CellClick"
                       DataMemberBinding="{Binding Filter3, Converter={StaticResource IntToBoolConverter}, Mode=TwoWay }" 
