            <Silverlight:ReportViewer Grid.Row="2" ReportServiceUri="../ReportService1.svc" Report="LexEnaReporting.EOP.KosztyRadcow.KosztyRadcow, LexEnaReporting" Name="WienaReportViewer" ParametersAreaVisible="True" RenderBegin="WienaReportViewer_RenderBegin" />



        </Grid >

    </Grid>
</UserControl>