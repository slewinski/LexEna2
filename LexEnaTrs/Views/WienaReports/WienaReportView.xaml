                    </telerik:RadGridView.GroupDescriptors>
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewDataColumn x:Name="Etap" Header="Etap"  Width="80" IsReadOnly="True"  DataMemberBinding="{Binding Filter}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Left" IsFilterable="False" ShowDistinctFilters="False"  ShowFieldFilters="False" ShowFilterButton="False" />
                        <telerik:GridViewDataColumn x:Name="Status" Header="Status" IsGroupable="False" Width="*" IsReadOnly="True"  DataMemberBinding="{Binding Nazwa}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Left" IsFilterable="False" ShowDistinctFilters="False" ShowFieldFilters="False" ShowFilterButton="False" />
                        <telerik:GridViewCheckBoxColumn   IsThreeState="False"
                                                    ShowDistinctFilters="False"
                                                    AutoSelectOnEdit="True"
                                                    EditTriggers="CellClick"
                       DataMemberBinding="{Binding Filter3, Converter={StaticResource IntToBoolConverter}, Mode=TwoWay }" 
                      HeaderTextAlignment="Center" TextAlignment="Left" Width="50" IsGroupable="False" IsFilterable="False" ShowFieldFilters="False" ShowFilterButton="False" >
