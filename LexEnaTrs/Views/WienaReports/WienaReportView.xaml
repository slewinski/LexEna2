                            </telerik:GridViewTableDefinition.Relation>
                        </telerik:GridViewTableDefinition>

                    </telerik:RadGridView.ChildTableDefinitions>
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewDataColumn x:Name="Id" Header="Lp." DataMemberBinding="{Binding numer}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="Status" Header="Info" DataMemberBinding="{Binding nazwa}" HeaderTextAlignment="Center" MinWidth="30" TextAlignment="Left" Width="120"  />
                        

                    </telerik:RadGridView.Columns>

                </telerik:RadGridView>
 -->
                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>

                    </Grid.RowDefinitions>
                    <sdk:Label x:Name="label2" HorizontalAlignment="Right" Height="28" Content="Od dnia-do dnia" VerticalAlignment="Center"  Grid.Row="0" Margin="0,0,2,0"/>


                    <telerik:RadComboBox  x:Name="cbRadca" FontSize="9"  SelectedValue="{Binding Oddzial, Mode=TwoWay}"  ItemsSource="{Binding typKancelarieWiena,  Source={StaticResource KonfiguracjaWiena}}"   SelectedValuePath="Numer" DisplayMemberPath="Nazwa" Margin="2,0,0,0" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Left" Width="211" VerticalAlignment="Center" Height="31" />
                    
                    <CheckBox Name="cbxDetails" IsThreeState="False"  Visibility="Collapsed" Margin="2,0,0,0"  Grid.Row="1" Grid.Column="1" HorizontalAlignment="Left" Width="211" VerticalAlignment="Center" Height="31" Content="Raport szczegółowy" Checked="cbxDetails_Checked" />

                    <Button Name="btProgress" Visibility="Collapsed"   Margin="2,0,0,0"  Grid.Row="2" Grid.Column="1" HorizontalAlignment="Left" Width="211" VerticalAlignment="Center" Height="31" Content="Sprawdź postęp obliczeń" Click="btProgress_Click" />
                    
                    <Button x:Name="btRun" Content="Wykonaj" Grid.Row="0" Grid.Column="2" HorizontalAlignment="Left"  VerticalAlignment="Center" Width="75" Margin="2,0,0,0" Click="btRun_Click"/>
                    <sdk:Label x:Name="labelKancelaria" HorizontalAlignment="Right" Height="28" Content="Kancelaria" VerticalAlignment="Bottom" Width="87" Grid.Row="1" Margin="0,0,2,11"/>
                    
                    <sdk:Label x:Name="labelStatusOdDo" Visibility="Collapsed" HorizontalAlignment="Right" Height="28" Content="Status od - do" VerticalAlignment="Bottom" Width="87" Grid.Row="1" Margin="0,0,2,11"/>
                    <telerik:RadDatePicker Name="rdpOdStatus" Visibility="Collapsed" Grid.Column="1" HorizontalAlignment="Left" Height="30" Grid.Row="1"  VerticalAlignment="Center" Width="100"  Margin="2,0,0,0"/>
                    <sdk:Label x:Name="labelkreskaOdDo" Visibility="Collapsed" HorizontalAlignment="Left" Grid.Column="1" Height="28" Content="-" VerticalAlignment="Center"  Grid.Row="1" Margin="124,0,2,0"/>
                    <telerik:RadDatePicker Name="rdpDoStatus" Visibility="Collapsed" Grid.Column="1" HorizontalAlignment="Left" Height="30" Grid.Row="1"  VerticalAlignment="Center" Width="100"  Margin="120,0,0,0"/>


                    <sdk:Label x:Name="labelPomin" HorizontalAlignment="Right" Height="28" Content="Pomiń dokumenty" VerticalAlignment="Center"  Grid.Row="2" Margin="0,0,2,0"/>
                    <telerik:RadDatePicker Name="rdpOd" Grid.Column="1" HorizontalAlignment="Left" Height="30" Grid.Row="0"  VerticalAlignment="Center" Width="100"  Margin="2,0,0,0"/>
                    <sdk:Label x:Name="labelkreska" HorizontalAlignment="Left" Grid.Column="1" Height="28" Content="-" VerticalAlignment="Center"  Grid.Row="0" Margin="124,0,2,0"/>

                    <sdk:Label x:Name="labelRodzajDok" HorizontalAlignment="Right" Height="28" Content="Dokument księgowy" VerticalAlignment="Center"  Grid.Row="2" Margin="0,0,2,0" Visibility="Collapsed"/>

                    <telerik:RadComboBox  x:Name="cbTypDok"  SelectedValue="{Binding TypDok, Mode=TwoWay}"  ItemsSource="{Binding typOznaczeniaDowodowWiena, Source={StaticResource SlownikDowodowWiena}}" Grid.Row="2" Grid.Column="1" IsEditable="True" SelectedValuePath="Nazwa" DisplayMemberPath="Nazwa" HorizontalAlignment="Left" Margin="10,0,0,17" Width="120" VerticalAlignment="Bottom" Height="19" Visibility="Collapsed"/>



                    <telerik:RadDatePicker Name="rdpDo" Grid.Column="1" HorizontalAlignment="Left" Height="30" Grid.Row="0"  VerticalAlignment="Center" Width="100"  Margin="120,0,0,0"/>
                    <TextBox x:Name="tbDocs" Grid.Column="1" Height="23" Margin="2,2,0,0" Grid.Row="2" TextWrapping="Wrap" Text="um;uz" Width="231" HorizontalAlignment="Left"/>


                </Grid>

