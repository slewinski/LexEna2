<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:riaControls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls.DomainServices" xmlns:my="clr-namespace:LexEnaTrs.Web" xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation" x:Class="LexEnaTrs.Views.ListaPaczek"
    mc:Ignorable="d"
    xmlns:local="clr-namespace:LexEnaTrs" 
     xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:DesignHeight="592" d:DesignWidth="800" Loaded="UserControl_Loaded" FontFamily="Portable User Interface">

    <Grid x:Name="LayoutRoot" Background="White">
        <Grid.Resources>
            <Style x:Key="MarkedRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}">
                <Setter Property="FontWeight" Value="Bold"/>
            </Style>

            <Style x:Key="NormalRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}"/>

            <local:PaczkiRowStatus x:Key="converter" />
            <local:ConditionalStyleSelector x:Key="PaczkiRowSelector"  ConditionConverter="{StaticResource converter}">
                <local:ConditionalStyleSelector.Rules>
                    <local:ConditionalStyleRule Style="{StaticResource MarkedRow}">
                        <local:ConditionalStyleRule.Value>
                            <sys:Int32>0</sys:Int32>
                        </local:ConditionalStyleRule.Value>
                    </local:ConditionalStyleRule>
                    <local:ConditionalStyleRule Style="{StaticResource NormalRow}">
                        <local:ConditionalStyleRule.Value>
                            <sys:Int32>1</sys:Int32>
                        </local:ConditionalStyleRule.Value>
                    </local:ConditionalStyleRule>
                    </local:ConditionalStyleSelector.Rules>
            </local:ConditionalStyleSelector>



        </Grid.Resources>
        <telerik:RadDomainDataSource AutoLoad="False" Height="0" PageSize="30"   x:Name="vw_ListaPaczekdds" QueryName="GetVw_ListaPaczekParamsQuery" Width="0" LoadingData="vw_ListaPaczekdds_LoadingData">
            <telerik:RadDomainDataSource.DomainContext>
                <my:LexEnaMeritumDomainContext />
            </telerik:RadDomainDataSource.DomainContext>
            <telerik:RadDomainDataSource.QueryParameters>
                <telerik:QueryParameter ParameterName="IdJednostki" />
                <telerik:QueryParameter ParameterName="StatusPaczki" />
                <telerik:QueryParameter ParameterName="TypDok" />

            </telerik:RadDomainDataSource.QueryParameters>
        </telerik:RadDomainDataSource>

        
        <telerik:RadDomainDataSource AutoLoad="False" Height="0"  PageSize="300" x:Name="vw_ListadokWysPaczkidds" QueryName="GetVw_ListaDokPaczkiByIdPaczkiQuery" Width="0" LoadingData="vw_ListadokWysPaczkidds_LoadingData">
            <telerik:RadDomainDataSource.DomainContext>
                <my:LexEnaMeritumDomainContext />
            </telerik:RadDomainDataSource.DomainContext>
            <telerik:RadDomainDataSource.QueryParameters>
                
                <telerik:QueryParameter ParameterName="IdPaczki" />
                

            </telerik:RadDomainDataSource.QueryParameters>
        </telerik:RadDomainDataSource>
         <Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="26"/>
				<RowDefinition Height="249*" />
                <RowDefinition Height="28*" />
                <RowDefinition Height="260*" />
                <RowDefinition Height="29"/>
			</Grid.RowDefinitions>
            <telerik:RadBusyIndicator x:Name="BusyIndicator" IsBusy="{Binding IsBusy, ElementName=vw_ListaPaczekdds}" Grid.Row="1" BusyContent="Przetwarzanie w toku..." Grid.RowSpan="3"></telerik:RadBusyIndicator>

            <telerik:RadDataPager x:Name="RadDataPagerSprawy" Source="{Binding DataView, ElementName=vw_ListaPaczekdds}" Grid.Row="2" DisplayMode="All" IsTotalItemCountFixed="True" Margin="493,0,0,0" VerticalAlignment="Top" d:LayoutOverrides="Height"  HorizontalAlignment="Left" Width="307"/>
            <Button Content="Usuń paczkę" Height="23" HorizontalAlignment="Left" Margin="4,0,0,0" Name="UsunPaczke" VerticalAlignment="Top" Width="102" />
            <Button Content="Zmień status" Height="23" HorizontalAlignment="Left" Margin="219,0,0,0" Name="ZmianaStatusu" VerticalAlignment="Top" Width="102" Click="ZmianaStatusu_Click" />
            <Button Content="Wyślij paczkę" Height="23" HorizontalAlignment="Left" Margin="112,0,0,0" Name="SendParcel" VerticalAlignment="Top" Width="102" Click="SendParcel_Click" />
            <telerik:RadGridView RowStyleSelector="{StaticResource PaczkiRowSelector}" IsSynchronizedWithCurrentItem="false" Grid.Row="1" x:Name="SprawyGridView" AutoGenerateColumns="false" SelectionMode="Single" IsReadOnly="True" ItemsSource="{Binding DataView, ElementName=vw_ListaPaczekdds}" AutoExpandGroups="True" CanUserFreezeColumns="False" RowIndicatorVisibility="Visible" Margin="0,6,0,0" SelectionChanged="SprawyGridView_SelectionChanged">
                <telerik:RadGridView.Columns>
                    <telerik:GridViewSelectColumn UniqueName="CurrentSprawa" />
                    <telerik:GridViewDataColumn x:Name="DataPaczki" Header="Data utworzenia" DataMemberBinding="{Binding DataZalozenia, StringFormat=\{0:d\}}"  DataFormatString=" {0:yyyy-MM-dd} "    IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                    <telerik:GridViewDataColumn x:Name="Oznaczenie" Header="Oznaczenie" DataMemberBinding="{Binding Oznaczenie}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                    <telerik:GridViewDataColumn x:Name="Rodzaj" Header="Nazwa dok." DataMemberBinding="{Binding TypDok, Converter={StaticResource TypDokConverter}}" IsReadOnly="True" IsFilterable="false" HeaderTextAlignment="Center" MinWidth="20" TextAlignment="Center" />
                    <telerik:GridViewDataColumn x:Name="DataWyslania" Header="Data wysł." DataMemberBinding="{Binding DataWyslania, StringFormat=\{0:d\}}"  DataFormatString=" {0:yyyy-MM-dd} " IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                    <telerik:GridViewDataColumn x:Name="StatusPaczki" Header="Status" DataMemberBinding="{Binding StatusPaczki, Converter={StaticResource StatusPaczkaConverter}}" IsReadOnly="True" IsFilterable="false" HeaderTextAlignment="Center" MinWidth="20" TextAlignment="Center" />
                    <telerik:GridViewDataColumn x:Name="LDoks" Header="Liczba dok." DataMemberBinding="{Binding LDoks}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                    <telerik:GridViewDataColumn Header="Opłata sądowa" DataMemberBinding="{Binding OplataSadowa ,StringFormat=\{0:c2\},ConverterCulture=pl-PL }" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                    <telerik:GridViewDataColumn Header="Prowizja oper." DataMemberBinding="{Binding OplataSadowa, Converter={StaticResource ObliczProwizje},StringFormat=\{0:c2\},ConverterCulture=pl-PL }" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                    <telerik:GridViewDataColumn Header="Wielkość paczki" DataMemberBinding="{Binding Wielkosc}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                </telerik:RadGridView.Columns>
            </telerik:RadGridView>

            <telerik:RadBusyIndicator x:Name="BusyIndicator2" IsBusy="{Binding IsBusy, ElementName=vw_ListadokWysPaczkidds}" Grid.Row="3" BusyContent="Odczyt danych proszę czekać...">
                <telerik:RadGridView   ValidatesOnDataErrors="None" IsSynchronizedWithCurrentItem="false"  Grid.Row="3" x:Name="DokPaczkiGridView" AutoGenerateColumns="false" SelectionMode="Multiple" IsReadOnly="True" ItemsSource="{Binding DataView, ElementName=vw_ListadokWysPaczkidds}" AutoExpandGroups="True" CanUserFreezeColumns="False" RowIndicatorVisibility="Visible" RowLoaded="DokPaczkiGridView_RowLoaded">

                    <telerik:RadGridView.Columns>
                        <telerik:GridViewSelectColumn UniqueName="CurrentSprawa" />
                        <telerik:GridViewDataColumn x:Name="Lp" Header="Lp"  IsReadOnly="True" IsFilterable="false" HeaderTextAlignment="Center"  TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="Referent" Header="Referent" DataMemberBinding="{Binding Uzytkownik_Nazwa}"  IsReadOnly="True" IsFilterable="false" HeaderTextAlignment="Center" MinWidth="20" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="NazwaDok" Header="Nazwa dok." DataMemberBinding="{Binding TypDok, Converter={StaticResource TypDokConverter}}"  IsReadOnly="True" IsFilterable="false" HeaderTextAlignment="Center" MinWidth="20" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DataDok" Header="Data dok." DataMemberBinding="{Binding DataDok, StringFormat=\{0:d\}}"  DataFormatString=" {0:yyyy-MM-dd} " IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="StatusDokum" Header="Status" DataMemberBinding="{Binding StatusDok, Converter={StaticResource StatusDocConverter}}"  IsReadOnly="True" IsFilterable="false" HeaderTextAlignment="Center" MinWidth="20" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="SygnaturaColumn" Header="Sygnatura" DataMemberBinding="{Binding sygnatura}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                        <telerik:GridViewDataColumn Header="Dłużnik" DataMemberBinding="{Binding Dluznik}" Width="*" HeaderTextAlignment="Center" MinWidth="150" TextAlignment="Left" />
                        <telerik:GridViewDataColumn Header="Oddział" DataMemberBinding="{Binding Oddzial}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn Header="Jednostka" DataMemberBinding="{Binding Nazwa_Jednostki}" IsReadOnly="True" IsFilterable="false" HeaderTextAlignment="Center" MinWidth="5" TextAlignment="Center" />
                        <telerik:GridViewDataColumn Header="Opłata sądowa" DataMemberBinding="{Binding Koszty ,StringFormat=\{0:c2\},ConverterCulture=pl-PL }" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn Header="Wielkość" DataMemberBinding="{Binding Wielkosc }" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DataDekret" Header="Data dekret." DataMemberBinding="{Binding DataDekretJednostka, StringFormat=\{0:d\}}"  DataFormatString=" {0:yyyy-MM-dd} "  IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
            </telerik:RadBusyIndicator>
            
            <telerik:RadDataPager x:Name="RadDataPagerDokPaczki" Source="{Binding DataView, ElementName=vw_ListadokWysPaczkidds}" Grid.Row="4" DisplayMode="All" IsTotalItemCountFixed="True" Margin="493,1,0,0" VerticalAlignment="Top" d:LayoutOverrides="Height"  HorizontalAlignment="Left" Width="307"/>
            <Button Content="Wycofaj z paczki" Grid.Row="2" Height="23" HorizontalAlignment="Left" Margin="6,5,0,0" Name="Wycofaj" VerticalAlignment="Stretch" Width="104" Click="Wycofaj_Click" />
            <telerik:RadDropDownButton Content="Raport"  Width="100"  Name="ExportRadDDB" Margin="114,5,0,0" HorizontalAlignment="Left" Grid.Row="2" Height="23">
                <telerik:RadDropDownButton.DropDownContent>
                <ListBox Name="FormatList" SelectionChanged="FormatList_SelectionChanged">
                        <ListBoxItem Content="Zestawienie do potwierdzenia sald"   />
                        <ListBoxItem Content="Wykaz spraw skierowanych do sądu" />
                        </ListBox>
                </telerik:RadDropDownButton.DropDownContent>

            </telerik:RadDropDownButton>
            <telerik:RadDropDownButton Content="Pokaż" Height="23" HorizontalAlignment="Left" Margin="219,5,0,0" Name="ShowDocs" Width="100" Grid.Row="2">
                <telerik:RadDropDownButton.DropDownContent>
                    <ListBox Name="ListaAkcji" SelectionChanged="ListaAkcji_SelectionChanged">
                        <ListBoxItem Content="Pokaż dokument" />
                        <ListBoxItem Content="Eksportuj zaznaczone" />
                    </ListBox>
                </telerik:RadDropDownButton.DropDownContent>
            </telerik:RadDropDownButton>
            <telerik:RadDropDownButton Content="Inne operacje" Height="23" HorizontalAlignment="Left" Margin="325,5,0,0" Name="OtherRadDropDownButton" Width="100" Grid.Row="2">
                <telerik:RadDropDownButton.DropDownContent>
                    <ListBox Name="listBoxOper" SelectionChanged="OperacjeLst_SelectionChanged">
                        <ListBoxItem Content="Zmień datę" />
                        <ListBoxItem Content="Zmień Pełnomocnika" />
                    </ListBox>
                </telerik:RadDropDownButton.DropDownContent>
            </telerik:RadDropDownButton>
            <Button x:Name="SynchronizeEpu" Content="Sprawdź w e-Sądzie" HorizontalAlignment="Left" Margin="326,0,0,0" Width="116" VerticalAlignment="Top" Click="SynchronizeEpu_Click"  />
            <Button x:Name="TestSynchro" Visibility="Collapsed"  Content="Test synchro" HorizontalAlignment="Left" Margin="500,0,0,0" Width="116" VerticalAlignment="Top" Click="TestSynchro_Click"  />
            <TextBox x:Name="IdSprawaOutput" Visibility="Collapsed" HorizontalAlignment="Left" Margin="600,0,0,0" Width="116" VerticalAlignment="Top"></TextBox>
        </Grid >
    </Grid>
</UserControl>
