<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
	xmlns:telerikGrid="clr-namespace:Telerik.Windows.Controls;assembly=Telerik.Windows.Controls.GridView"
    xmlns:local="clr-namespace:LexEnaTrs"
   	xmlns:my="clr-namespace:LexEnaTrs.Web"
	x:Class="LexEnaTrs.Views.SadySprView"
    mc:Ignorable="d"
    d:DesignHeight="282" d:DesignWidth="400" Loaded="UserControl_Loaded">
    
    <Grid x:Name="LayoutRoot" DataContext="{Binding ElementName=SadSprawaDomainDataSource, Path=Data}" Background="White">
    	<Grid.RowDefinitions>
    		<RowDefinition Height="27"/>
    		<RowDefinition/>
    	</Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="2,2,0,2"  d:LayoutOverrides="HorizontalAlignment, GridBox" Width="250" HorizontalAlignment="Left">
            <Button  Content="Dodaj sąd" x:Name="AddSSad" Width="75"  HorizontalAlignment="Left" Click="AddSSad_Click"   />
            <Button Content="Szczegóły" x:Name="Details" Width="75"  HorizontalAlignment="Left" Margin="10,0,0,0" Click="Details_Click"/>
            <Button Content="Usuń sąd" x:Name="DelSad" Width="75" Click="DelSadSprawa_Click" HorizontalAlignment="Left" Margin="10,0,0,0"/>
        </StackPanel>
        <telerik:RadGridView x:Name ="gridViewSadSprawa"  RowIndicatorVisibility="Collapsed"   Grid.Row="1" ItemsSource="{Binding DataView, ElementName=SadSprawaDomainDataSource}" AutoGenerateColumns="False" Margin="0,2,8,8" ShowGroupPanel="False" Grid.RowSpan="2" >
    					<telerik:RadGridView.Columns>
    						
    						<local:DateTimePickerColumn MinWidth="20" Header="D skierowania" IsReadOnly="True"  DataMemberBinding="{Binding d_skierowania, Mode=OneWay}" DataFormatString="{}{0:yyyy-MM-dd}" IsFilterable="false"  SortMemberPath="Value" SortingState="Ascending" HeaderTextAlignment="Center"  TextAlignment="Center"  />
                <telerik:GridViewDataColumn MinWidth="20" Header="Sygnatura" IsReadOnly="True"  DataMemberBinding="{Binding sygnatura, Mode=OneWay}"  IsFilterable="false"  HeaderTextAlignment="Center"  TextAlignment="Center"  />
                <telerik:GridViewComboBoxColumn EditTriggers="CellClick"  IsReadOnly="True" Header="Sąd" Width="*"  DataMemberBinding="{Binding sad_id, Mode=OneWay}" IsFilterable="false"  HeaderTextAlignment="Center" MinWidth="5" TextAlignment="Center"  
							      ItemsSource= "{Binding dictionarySady, Source={StaticResource SadyList} }"
								SelectedValueMemberPath="id" 
                                DisplayMemberPath="nazwa"
							
							/>
							<!--							
                          	<telerik:GridViewComboBoxColumn EditTriggers="CellClick"  Header="Status" Width="*"  DataMemberBinding="{Binding NazwaStatusu_Id, Mode=TwoWay}" IsFilterable="false"  HeaderTextAlignment="Center" MinWidth="5" TextAlignment="Center"  
							     ItemsSource="{Binding dictionaryStatusy, Source={StaticResource StatusyList}}"
								SelectedValueMemberPath="Id" 
                                DisplayMemberPath="Nazwa"
							
							/> -->
    					</telerik:RadGridView.Columns>
							
    				</telerik:RadGridView>
        <telerik:RadDomainDataSource  AutoLoad="False"  Height="0"  Name="SadSprawaDomainDataSource" QueryName="GetSadSprawaBySprIdQuery" Width="0" LoadedData="SadSprawaDomainDataSource_LoadedData" Margin="200,90,200,141" Grid.Row="1">
            <telerik:RadDomainDataSource.DomainContext>
                <my:LexEnaMeritumDomainContext />
        </telerik:RadDomainDataSource.DomainContext>
            <telerik:RadDomainDataSource.QueryParameters>
                <telerik:QueryParameter ParameterName="IdSprawy" />
        </telerik:RadDomainDataSource.QueryParameters>
        </telerik:RadDomainDataSource >
    </Grid>
</UserControl>
