                    <Grid.RowDefinitions>
                        <RowDefinition Height="211"/>
                    </Grid.RowDefinitions>
                    <telerik:DataFormDataField x:Name="Numer" LabelPosition="Beside" Label="Nr" DataMemberBinding="{Binding Numer, Mode=TwoWay}" Margin="2,0,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="105"/>
                    <telerik:DataFormDataField   VerticalAlignment="Top" LabelPosition="Beside" VerticalContentAlignment="Stretch" Grid.Column="1" x:Name="Wartosc" Label="Wartość"  DataMemberBinding="{Binding Wartosc, Mode=TwoWay}" HorizontalAlignment="Left" Width="194" Margin="0,2,0,0"  >
