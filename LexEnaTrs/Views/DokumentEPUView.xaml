					</telerik:DataFormDataField>
					<telerik:DataFormDataField Margin="0,20,4,0"  Label = "Typ" LabelPosition="Above" x:Name="Typ"  DataMemberBinding="{Binding Typ, Mode=TwoWay}"   VerticalAlignment="Top" Grid.ColumnSpan="1" d:LayoutOverrides="GridBox">
                        <telerik:RadComboBox  ItemsSource="{Binding rodzajRoszczenia, Source={StaticResource RodzajeRoszczen}}"  SelectedIndex="{Binding Typ, Mode=TwoWay}" DisplayMemberPath="Nazwa"  SelectedValuePath="Numer" Margin="0,0,-23,0" />	
					</telerik:DataFormDataField>
					<telerik:DataFormDataField Margin="8,20,0,0"  LabelPosition="Above"   DataMemberBinding="{Binding Solidarnie, Mode=TwoWay}"   VerticalAlignment="Top" Grid.Column="1" Grid.ColumnSpan="1" HorizontalAlignment="Left" Width="182" d:LayoutOverrides="GridBox" Height="46">
