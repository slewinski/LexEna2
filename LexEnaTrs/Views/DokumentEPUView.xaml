                    </telerik:DataFormDataField>
                    <telerik:DataFormDataField Margin="8,20,0,0"  LabelPosition="Above"   DataMemberBinding="{Binding Solidarnie, Mode=TwoWay}"   VerticalAlignment="Top" Grid.Column="1" Grid.ColumnSpan="1" HorizontalAlignment="Left" Width="182" d:LayoutOverrides="GridBox" Height="46">
                        <telerik:RadComboBox  ItemsSource="{Binding rodzajSolidarnosci, Source={StaticResource RodzajeSolidarnosci}}"  SelectedIndex="{Binding Solidarnie, Mode=TwoWay}" DisplayMemberPath="Nazwa" SelectedValuePath="Numer"  Margin="50,0,-16,0" />
                    </telerik:DataFormDataField>
                    <telerik:DataFormDataField   VerticalAlignment="Top" VerticalContentAlignment="Stretch" x:Name="Opis" Label="Opis"  DataMemberBinding="{Binding Opis, Mode=TwoWay}" LabelPosition="Beside" Grid.ColumnSpan="2" Margin="0,66,0,0" Background="#00A36969" >
                        <TextBox Text="{Binding Opis, Mode=TwoWay}"
         		    Height="43"
					IsReadOnly="True"
             		VerticalScrollBarVisibility="Auto"
            		HorizontalScrollBarVisibility="Auto"
            		AcceptsReturn="True" Margin="-71,0,-7,0"  />
                    </telerik:DataFormDataField>
                    <TextBlock HorizontalAlignment="Right" TextAlignment="Right"	 Margin="0,29,140,0" TextWrapping="Wrap" Text="Sposób zasądzenia" VerticalAlignment="Top" Height="34" Width="72" Grid.Column="1"/>
                </Grid>



            </DataTemplate>

