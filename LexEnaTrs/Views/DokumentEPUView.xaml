				</telerik:DataFormDataField>

				
		   	</Grid>
        </DataTemplate>
	 		   <DataTemplate x:Key="dataFormTemplateRoszczenia">
	 		  	<Grid Height="115" d:DesignWidth="285" Width="342" >
