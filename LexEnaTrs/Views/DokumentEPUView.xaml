                    <TextBox Grid.Row="1" Height="307" HorizontalAlignment="Left" Margin="6,113,0,0" Name="textBox2" VerticalAlignment="Top" Text="{Binding Tresc, Mode=TwoWay}" AcceptsReturn="True"  Width="766" TextWrapping="Wrap" />
                    <TextBlock FontWeight="Bold" Height="20" HorizontalAlignment="Right" Margin="0,12,631,0" Text="Przedmiot (tytuł)" TextAlignment="Right" TextWrapping="Wrap" VerticalAlignment="Top" Width="136" Grid.Row="1" />
