				<telerik:DataFormDataField x:Name="Oznaczenie"  Grid.ColumnSpan="3" DataMemberBinding="{Binding Oznaczenie, Mode=TwoWay}" Margin="-125,2,72,2" Grid.Row="1" ToolTipService.ToolTip="Podaj oznaczenie dokumentu - dowodu ( numer faktury, oznaczenie aktu notarialnego , numer umowy ) "/>
