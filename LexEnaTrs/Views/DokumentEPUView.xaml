                        <RowDefinition Height="0.061*"/>
                        <RowDefinition Height="0.702*"/>
                    
                    </Grid.RowDefinitions>

                    <TextBox TextWrapping="NoWrap"  IsReadOnly="True" Height="21" x:Name="Sygnatura" Text="{Binding Sygnatura, Mode=TwoWay}" Margin="0,3,143,0"  VerticalAlignment="Top" HorizontalAlignment="Right" Width="198"/>
