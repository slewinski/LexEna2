					<telerik:DataFormDateField  Grid.Column="2" TabIndex="2" Margin="2" Label="Data dowodu"  DataMemberBinding="{Binding DataDowodu, Converter={StaticResource DateConverter}, Mode=TwoWay}"  x:Name="DataDowodu"  VerticalAlignment="Center" FontSize="10.667" ToolTipService.ToolTip="Data dokumentu stanowiacego dowód ( jeśli istnieje)"/>
				<!--<telerik:DataFormDataField Margin="0,0,27,3" Grid.Row="2" Label = "Fakt podlegający stwierdzeniu" x:Name="FaktStwierdzony" DataMemberBinding="{Binding FaktStwierdzany, Mode=TwoWay}" LabelPosition="Above" d:LayoutOverrides="HorizontalAlignment" Grid.ColumnSpan="3" RenderTransformOrigin="0.5,0.5" Background="#00E2BCBC"/> -->
				 <telerik:DataFormDataField  Grid.Row="2" LabelPosition="Above" x:Name="FaktStwierdzony" Grid.ColumnSpan="2" DataMemberBinding="{Binding FaktStwierdzany, Mode=TwoWay}" Margin="2,2,-2,17" >
