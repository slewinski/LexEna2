    			</Grid>
    		</telerik:RadTabItem>
    		<telerik:RadTabItem x:Name="ChecktabItem" Header="Sprawdzenie">

               
                <Grid Background="White">
                    <telerik:RadDomainDataSource AutoLoad="False" Height="0" PageSize="30"   x:Name="vw_KomunikacjaDocWysdds" QueryName="GetVw_KomunikacjaDocByIdDocQuery" Width="0"  >
                        <telerik:RadDomainDataSource.DomainContext>
                            <my:LexEnaMeritumDomainContext />
                        </telerik:RadDomainDataSource.DomainContext>
                        <telerik:RadDomainDataSource.QueryParameters>
                            <telerik:QueryParameter ParameterName="IdDocWys" />
                       </telerik:RadDomainDataSource.QueryParameters>
                    </telerik:RadDomainDataSource>
                    <telerik:RadGridView Name="GridViewDokKomunikacja" IsReadOnly="True"  ItemsSource="{Binding DataView, ElementName=vw_KomunikacjaDocWysdds}" AutoExpandGroups="False" CanUserFreezeColumns="False" RowIndicatorVisibility="Visible"  Margin="8,0,8,16" IsFilteringAllowed="False" AutoGenerateColumns="False" ShowGroupPanel="False" >
