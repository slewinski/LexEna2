<controls:ChildWindow
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
           xmlns:controls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls"
           xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation" x:Class="LexEnaTrs.Views.AddSadSprawa"
           Width="709" Height="300" 
           Title="Sąd rozpoznający sprawę" Loaded="ChildWindow_Loaded">
    <Grid x:Name="LayoutRoot" Margin="0,0,4,4">

		
		<Grid >
			<Grid.RowDefinitions>
				<RowDefinition Height="52*"/>
				<RowDefinition Height="57*"/>
				<RowDefinition Height="39*"/>
				
				<RowDefinition Height="74*"/>
				<RowDefinition Height="43*"/>
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
			<ColumnDefinition Width="100"/>
			<ColumnDefinition Width="7*"/>
			<ColumnDefinition Width="221*"/>
		</Grid.ColumnDefinitions>

			<Button x:Name="CancelButton" Content="Anuluj"  Click="CancelButton_Click" Width="70" HorizontalAlignment="Right"  Margin="0,10,2,5" Grid.Row="4" Grid.Column="2"/>
			<Button x:Name="OKButton" Content="OK" Click="OKButton_Click" Width="75" HorizontalAlignment="Right"  Grid.Column="2" Grid.Row="4" Margin="0,10,75,5" RenderTransformOrigin="1.24,0.348" />
            <controls:DatePicker  SelectedDate="{Binding d_skierowania, Mode=TwoWay}" Grid.Column="2" HorizontalAlignment="Left" Margin="5,10,0,0" VerticalAlignment="Top" Height="24" Width="109"/>
			<TextBlock HorizontalAlignment="Right" Height="34" TextWrapping="Wrap" Text="Data skierowania" TextAlignment="Right" VerticalAlignment="Center" Width="80" Margin="0,9" FontWeight="Bold"/>
			<TextBlock HorizontalAlignment="Right" Height="20" TextWrapping="Wrap" Text="Sygnatura" TextAlignment="Right" VerticalAlignment="Center" Width="80"  Grid.Row="1" Margin="0,19,0,18" FontWeight="Bold"/>
			<TextBlock HorizontalAlignment="Right" Height="20" TextWrapping="Wrap" Text="Sąd" TextAlignment="Right" VerticalAlignment="Center" Width="80"  Grid.Row="2" Margin="0,13,0,6" FontWeight="Bold"/>
			<TextBlock HorizontalAlignment="Right" Height="20" TextWrapping="Wrap" Text="Uwagi" TextAlignment="Right" VerticalAlignment="Center" Width="80"  Grid.Row="3"  FontWeight="Bold" Margin="0,54,0,0"/>
            <TextBox x:Name="tbSygnatura" Grid.Column="2" Text="{Binding sygnatura, Mode=TwoWay}" HorizontalAlignment="Left" Height="23" Margin="5,19,0,0" Grid.Row="1" TextWrapping="Wrap"  VerticalAlignment="Top" Width="120"/>
            <telerik:RadComboBox Grid.Column="2"    ItemsSource= "{Binding dictionarySady, Source={StaticResource SadyList} }" SelectedValue="{Binding sad_id, Mode=TwoWay}" SelectedValuePath="id" DisplayMemberPath="nazwa" HorizontalAlignment="Left"  Grid.Row="2" VerticalAlignment="Center" Width="567" Margin="0,10,0,9" Height="20">
				
			</telerik:RadComboBox>
            <TextBox Grid.Column="2"  Grid.Row="3" TextWrapping="Wrap" Text="{Binding uwagi, Mode=TwoWay}" VerticalContentAlignment="Top" HorizontalContentAlignment="Left" />
		</Grid>
	</Grid>
</controls:ChildWindow>