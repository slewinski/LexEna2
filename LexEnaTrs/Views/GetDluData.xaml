<controls:ChildWindow
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
           xmlns:controls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls"
           xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" mc:Ignorable="d" x:Class="LexEnaTrs.Views.GetDluData"
           Width="635.947" Height="285.053" 
           Title="Dane dłużnika" Loaded="ChildWindow_Loaded">
    <Grid x:Name="LayoutRoot" Margin="2">
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="43*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60*"/>
            <ColumnDefinition Width="179*"/>
        </Grid.ColumnDefinitions>

        <Button x:Name="CancelButton" Content="Anuluj" Click="CancelButton_Click" Width="75" HorizontalAlignment="Right" Margin="0,23,0,0"  Grid.Row="8" Grid.Column="1" />
        <Button x:Name="OKButton" Content="OK" Click="OKButton_Click" Margin="0,23,80,0" Grid.Column="1" Grid.Row="8" HorizontalAlignment="Right" Width="80" />
        <sdk:Label x:Name="label0" HorizontalAlignment="Right"   Content="System źródłowy" Grid.Column="0" Grid.Row="0" FontSize="9" FontWeight="Bold" Width="146"/>
        <sdk:Label x:Name="label" HorizontalAlignment="Right"   Content="Nazwa dłużnika ( nazwisko )" Grid.Column="0" Grid.Row="1" FontSize="9" FontWeight="Bold" Width="146"/>
        <sdk:Label x:Name="label1" HorizontalAlignment="Right" Margin="0" Grid.Row="2" Content="Imię ( osoby fizyczne)" Width="136" FontSize="9" FontWeight="Bold"/>
        <sdk:Label x:Name="label2" HorizontalAlignment="Right" Margin="0" Grid.Row="3" Content="Nip (osoba prawna)" Width="117" FontSize="9" FontWeight="Bold"/>
        <sdk:Label x:Name="label3" HorizontalAlignment="Right"  Grid.Row="4" Width="98" Content="Pesel (osoba fizyczna)" Margin="0" FontSize="9" FontWeight="Bold"/>
        <sdk:Label x:Name="label4" HorizontalAlignment="Right"  Grid.Row="5" Width="144" Content="Adres(1) ulica, dom" Margin="0" FontSize="9" FontWeight="Bold"/>
        <sdk:Label x:Name="label5" HorizontalAlignment="Right"  Grid.Row="6" Width="154" Content="Adres(2) kod, miejscowość" Margin="0" FontSize="9" FontWeight="Bold"/>
        <sdk:Label x:Name="label6" HorizontalAlignment="Right"  Grid.Row="7" Width="126" Content="Nr Klienta w systemie" Margin="0" FontSize="9" FontWeight="Bold"/>
        <TextBox x:Name="tbImie" Grid.Column="1" Grid.Row="2" TextWrapping="Wrap"  FontSize="9" Margin="3"/>
        <telerik:RadMaskedTextInput x:Name="tbNIP"   Mask="##########" Grid.Column="1" Grid.Row="3"  FontSize="9" Margin="3,3,363,3"/>
        <telerik:RadMaskedTextInput x:Name="tbPESEL"   Mask="###########"  Grid.Column="1" Grid.Row="4"   FontSize="9" Margin="3,3,363,3"/>
        <TextBox x:Name="tbAdres1" Grid.Column="1" Grid.Row="5"   FontSize="9" Margin="3"/>
        <TextBox x:Name="tbAdres2" Grid.Column="1" Grid.Row="6"  FontSize="9" Margin="3"/>
        <TextBox x:Name="tbNrKlienta" Grid.Column="1" Grid.Row="7" TextWrapping="Wrap"  FontSize="9" Margin="3,3,285,3"/>
        <TextBox x:Name="tbNazwa" Grid.Column="1" Grid.Row="1" TextWrapping="Wrap"  Margin="3,3,3,3" FontSize="9"/>
        <telerik:RadComboBox Name ="cbSrcSystem" DataContext="{StaticResource SlownikSystemow}" ItemsSource="{Binding rodzajSystemu}"  DisplayMemberPath="Nazwa" SelectedValuePath="Numer" Grid.Column="1" HorizontalAlignment="Left" Margin="3,3,3,3" Grid.Row="0"    Width="150">
        </telerik:RadComboBox>
    </Grid>
</controls:ChildWindow>