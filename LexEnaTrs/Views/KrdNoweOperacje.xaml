<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:riaControls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls.DomainServices" xmlns:my="clr-namespace:LexEnaTrs.Web" xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation" x:Class="LexEnaTrs.Views.KrdNoweOperacje"
    mc:Ignorable="d"
    xmlns:local="clr-namespace:LexEnaTrs" 
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:DesignHeight="592" d:DesignWidth="800" Loaded="UserControl_Loaded" FontFamily="Portable User Interface">

    <Grid x:Name="LayoutRoot" Background="White">

        <telerik:RadDomainDataSource AutoLoad="False" Height="0" PageSize="40"   x:Name="GetBIG_ImportByDatedds" QueryName="GetBIG_ImportByDateQuery" Width="0"  LoadingData="GetBIG_ImportByDate_LoadingData">
            <telerik:RadDomainDataSource.DomainContext>
                <my:LexEnaMeritumDomainContext />
            </telerik:RadDomainDataSource.DomainContext>

        </telerik:RadDomainDataSource>
        <telerik:RadDomainDataSource AutoLoad="False" Height="0"  PageSize="400" x:Name="BIGvw_ImportyDetaildds" QueryName="GetBIGvw_ImportyDetailByImportIdQuery" Width="0" LoadingData="BIGvw_ImportyDetaildds_LoadingData">
            <telerik:RadDomainDataSource.DomainContext>
                <my:LexEnaMeritumDomainContext />
            </telerik:RadDomainDataSource.DomainContext>
            <telerik:RadDomainDataSource.QueryParameters>

                <telerik:QueryParameter ParameterName="Import_Id" />


            </telerik:RadDomainDataSource.QueryParameters>
        </telerik:RadDomainDataSource>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="249*" />
                <RowDefinition Height="28*" />
                <RowDefinition Height="260*" />
                <RowDefinition Height="29"/>
            </Grid.RowDefinitions>
            <Grid.Resources>
                <Style x:Key="SentRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}">
                    <Setter Property="Background" Value="#00ffff" />
                    <Setter Property="FontWeight" Value="Normal"/>
                </Style>
                <Style x:Key="QuedRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}">
                    <Setter Property="Background" Value="#33ccff" />

                </Style>
                <Style x:Key="PrecessingRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}">
                    <Setter Property="Background" Value="#0066ff" />
                </Style>
                <Style x:Key="SuccessRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}">
                    <Setter Property="Background" Value="#00cc00" />
                </Style>
                <Style x:Key="FailureRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}">
                    <Setter Property="Background" Value="#ff0000" />
                </Style>
                <Style x:Key="ErrorRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}">
                    <Setter Property="Background" Value="#ff5c33" />
                </Style>
                <Style x:Key="NormalRow" TargetType="telerik:GridViewRow" BasedOn="{StaticResource GridViewRowStyle}"/>

                <local:ImportBIGRowStatus x:Key="converter" />
                <local:ConditionalStyleSelector x:Key="selector"  ConditionConverter="{StaticResource converter}">
                    <local:ConditionalStyleSelector.Rules>
                        <local:ConditionalStyleRule Style="{StaticResource NormalRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>0</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource SentRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>1</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource QuedRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>3</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource PrecessingRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>4</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource SuccessRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>200</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource ErrorRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>199</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource FailureRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>-1</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                    </local:ConditionalStyleSelector.Rules>
                </local:ConditionalStyleSelector>


                <local:ImportBIGDetailRowStatus x:Key="converterDetail" />
                <local:ConditionalStyleSelector x:Key="selectorDetail"  ConditionConverter="{StaticResource converterDetail}">
                    <local:ConditionalStyleSelector.Rules>
                        <local:ConditionalStyleRule Style="{StaticResource NormalRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>0</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource SuccessRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>1</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                        <local:ConditionalStyleRule Style="{StaticResource FailureRow}">
                            <local:ConditionalStyleRule.Value>
                                <sys:Int32>-1</sys:Int32>
                            </local:ConditionalStyleRule.Value>
                        </local:ConditionalStyleRule>
                    </local:ConditionalStyleSelector.Rules>
                </local:ConditionalStyleSelector>

            </Grid.Resources>



            <telerik:RadBusyIndicator x:Name="BusyIndicator" IsBusy="{Binding IsBusy, ElementName=GetBIG_ImportByDatedds}" Grid.Row="1" BusyContent="Przetwarzanie w toku...">
                <telerik:RadGridView ValidatesOnDataErrors="None" RowStyleSelector="{StaticResource selector}" IsSynchronizedWithCurrentItem="false"  Grid.Row="1" x:Name="SprawyGridView" AutoGenerateColumns="false" SelectionMode="Single" IsReadOnly="True" ItemsSource="{Binding DataView, ElementName=GetBIG_ImportByDatedds}" AutoExpandGroups="True" CanUserFreezeColumns="False" RowIndicatorVisibility="Visible" SelectionChanged="SprawyGridView_SelectionChanged"  FilteringMode="FilterRow" EnableColumnVirtualization="False" CanUserReorderColumns="False">
                    <telerik:RadContextMenu.ContextMenu>
                        <telerik:RadContextMenu x:Name="GridContextMenu">
                            <telerik:RadMenuItem Header="Pokaż szczegóły" Click="DetailsItem_Click"  />
                            <telerik:RadMenuItem Header="Szukaj" Click="SearchItem_Click"  />
                        </telerik:RadContextMenu>
                    </telerik:RadContextMenu.ContextMenu>

                    <telerik:RadGridView.Columns>



                        <telerik:GridViewDataColumn x:Name="DataI" Header="Data importu" DataMemberBinding="{Binding DataImportu, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn Header="Nazwa zbioru" DataMemberBinding="{Binding Filename}" Width="200" HeaderTextAlignment="Center" MinWidth="150" TextAlignment="Left" />

                        <telerik:GridViewDataColumn x:Name="StatusOper" Header="Status" DataMemberBinding="{Binding Status}"  IsReadOnly="True"  HeaderTextAlignment="Center" MinWidth="20" TextAlignment="Center" />

                        <telerik:GridViewDataColumn x:Name="OpisOper" Header="Opis operacji" DataMemberBinding="{Binding StatOpis}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DataW" Header="Data wys do BIG" DataMemberBinding="{Binding DataWysylki, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />

                        <telerik:GridViewDataColumn Header="Liczba pozycji" DataMemberBinding="{Binding lPoz}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn Header="Operator" DataMemberBinding="{Binding Username}" IsReadOnly="True" IsFilterable="True" HeaderTextAlignment="Center" MinWidth="5" TextAlignment="Center" />

                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
            </telerik:RadBusyIndicator>

            <telerik:RadDataPager x:Name="RadDataPagerSprawy" Source="{Binding DataView, ElementName=GetBIG_ImportByDatedds}" Grid.Row="2" DisplayMode="All" IsTotalItemCountFixed="True" Margin="0,2,0,0" VerticalAlignment="Top" d:LayoutOverrides="Height"  HorizontalAlignment="Right" Width="307"/>

            <telerik:RadBusyIndicator x:Name="BusyIndicator2" IsBusy="{Binding IsBusy, ElementName=BIGvw_ImportyDetaildds}" Grid.Row="3" BusyContent="Odczyt danych proszę czekać...">
                <telerik:RadGridView ValidatesOnDataErrors="None" RowStyleSelector="{StaticResource selectorDetail}" FilteringMode="FilterRow" IsSynchronizedWithCurrentItem="false"  Grid.Row="3" x:Name="ImportDetailsGridView" AutoGenerateColumns="false" SelectionMode="Multiple" IsReadOnly="True" ItemsSource="{Binding DataView, ElementName=BIGvw_ImportyDetaildds}" AutoExpandGroups="True" CanUserFreezeColumns="False" RowIndicatorVisibility="Visible" >

                    <telerik:RadGridView.Columns>

                        <telerik:GridViewDataColumn x:Name="Lp" Header="Lp"  IsReadOnly="True" DataMemberBinding="{Binding Row}"  IsFilterable="false" HeaderTextAlignment="Center"  TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="TypOperacjiColumn" Header="Operacja" DataMemberBinding="{Binding TypOperacji}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="StatusO" Header="Status" DataMemberBinding="{Binding StatusOperacji}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="StatusOpois" Header="Status" DataMemberBinding="{Binding StatOpis}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="SystemColumn" Header="System" DataMemberBinding="{Binding System}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="NameColumn" Header="Nazwa/Nazwisko" DataMemberBinding="{Binding Name}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="FirstNameColumn" Header="Imię" DataMemberBinding="{Binding Firstname}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="A1Column" Header="Adres" DataMemberBinding="{Binding Address1L1}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="A2Column" Header="Adres(2)" DataMemberBinding="{Binding Address1L2}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="CliNo" Header="Nr Klienta" DataMemberBinding="{Binding NrKlienta}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="IdNumber" Header="NIP/Pesel" DataMemberBinding="{Binding IDNumber}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="Nrfaktury" Header="Nr Faktury" DataMemberBinding="{Binding Title}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="DataWymag" Header="Data wymagalności" DataMemberBinding="{Binding DataWymag, StringFormat=\{0:yyyy-MM-dd\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn Header="Należnośc" DataMemberBinding="{Binding Saldo ,StringFormat=\{0:c2\},ConverterCulture=pl-PL }" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DataSuspend" Header="Data zawieszenia" DataMemberBinding="{Binding SuspendDate, StringFormat=\{0:yyyy-MM-dd\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DataNotify" Header="Data zawiadom." DataMemberBinding="{Binding NotifyDate, StringFormat=\{0:yyyy-MM-dd\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DataImpDet" Header="Data wysłania" DataMemberBinding="{Binding DataOperacji, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DataProcedowaniaKrd" Header="Data przetworzenia" DataMemberBinding="{Binding DataProcedowaniaKrd, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />

                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
            </telerik:RadBusyIndicator>

            <telerik:RadDataPager x:Name="RadDataPagerImportDetails" Source="{Binding DataView, ElementName=BIGvw_ImportyDetaildds}" Grid.Row="4" DisplayMode="All" IsTotalItemCountFixed="True" Margin="493,1,0,0" VerticalAlignment="Top" d:LayoutOverrides="Height"  HorizontalAlignment="Right" Width="307"/>
            <Button x:Name="btExport" Content="Eksport do XLS" HorizontalAlignment="Left" Margin="10,4,0,0" Grid.Row="2" VerticalAlignment="Top" Width="120" Click="btExport_Click"/>
            <Button x:Name="SendToKrd" Content="Wyślij do KRD" HorizontalAlignment="Left" Margin="253,1,0,0" VerticalAlignment="Top" Width="120" Click="SendToKrd_Click"/>
            <Button x:Name="btCheckKrd" Content="Sprawdź status" HorizontalAlignment="Left" Margin="377,1,0,0" VerticalAlignment="Top" Width="120" Click="btCheckKrd_Click"/>
            <Button x:Name="btImpWiena" Content="Importuj z Systemu" HorizontalAlignment="Left" Margin="128,1,0,0" Width="120" VerticalAlignment="Top" Click="btImpWiena_Click" />
     
            <Button x:Name="btDelImport" Content="Usuń" HorizontalAlignment="Left" Margin="500,1,0,0" VerticalAlignment="Top" Width="120" Click="btDelImport_Click" />
            <Button x:Name="btDelAll" Content="Wykreśl wszystkich" HorizontalAlignment="Left" Margin="623,1,0,0" VerticalAlignment="Top" Width="120" Click="btDelAll_Click"   />

            <telerik:RadDropDownButton AutoOpenDelay="0:0:0.5" x:Name="rdbImport" CloseOnPopupMouseLeftButtonUp="True" Content="Importuj csv"  IsOpen="False" HorizontalAlignment="Left" Margin="4,1,0,0"  Width="120" VerticalAlignment="Top">
                <telerik:RadDropDownButton.DropDownContent>
                    <ListBox Name="ListaAkcji" SelectionChanged="ListaAkcji_SelectionChanged"  >
                        <ListBoxItem Name="BillingAll" Content="Inicjalny z systemów billingowych" MouseLeftButtonUp="BillingAll_MouseLeftButtonUp"  />
                        <ListBoxItem Name="WienaAll" Content="Inicjalny z Wieny" MouseLeftButtonUp="WienaAll_MouseLeftButtonUp" />
                        <ListBoxItem Name ="BillingUpdate" Content="Aktualizujący z Systemów billingowych" MouseLeftButtonUp="BillingUpdate_MouseLeftButtonUp" />
                        <ListBoxItem Name ="CCnBAll" Content="Z systemu CCnB" MouseLeftButtonUp="CCnBAll_MouseLeftButtonUp"  />
                        <ListBoxItem Name ="SelenPzP" Content="Selen pozaprądowy" MouseLeftButtonUp="SelenPzP_MouseLeftButtonUp"  />
                        <ListBoxItem Name ="AumsEOP" Content="AUMS-EOP" MouseLeftButtonUp="AumsEOP_MouseLeftButtonUp" />
                        <ListBoxItem Name ="CCnBAllNew" Content="Z systemu CCnB -EOB - nowy format" MouseLeftButtonUp="CCnBAllNew_MouseLeftButtonUp"  />
                        <ListBoxItem Name ="SapEOP" Content="SAP-EOP" MouseLeftButtonUp="SapEOP_MouseLeftButtonUp"  />
                    </ListBox>
                </telerik:RadDropDownButton.DropDownContent>
            </telerik:RadDropDownButton>

        </Grid >
    </Grid>
</UserControl>
