<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
	xmlns:telerikGrid="clr-namespace:Telerik.Windows.Controls;assembly=Telerik.Windows.Controls.GridView"
    xmlns:local="clr-namespace:LexEnaTrs"
   	xmlns:my="clr-namespace:LexEnaTrs.Web"
	x:Class="LexEnaTrs.Views.StatusyView"
    mc:Ignorable="d"
    d:DesignHeight="282" d:DesignWidth="400" Loaded="UserControl_Loaded">
    
    <Grid x:Name="LayoutRoot" DataContext="{Binding ElementName=StatusySprawyDomainDataSource, Path=Data}" Background="White">
    	<Grid.RowDefinitions>
    		<RowDefinition Height="27"/>
    		<RowDefinition/>
    	</Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="2,2,0,2"  d:LayoutOverrides="HorizontalAlignment, GridBox" Width="163" HorizontalAlignment="Left">
            <telerik:RadButton  Content="Dodaj status" x:Name="AddStatus" Width="75"  HorizontalAlignment="Left"  Command="telerikGrid:RadGridViewCommands.BeginInsert"  CommandTarget="{Binding ElementName=gridViewStatusySprawy}" />
           
    					<Button Content="Usuń status" x:Name="DelSatatus" Width="75" Click="DelSatatus_Click" HorizontalAlignment="Left" Margin="10,0,0,0"/>
    				</StackPanel>
    	<telerik:RadGridView x:Name ="gridViewStatusySprawy"  RowIndicatorVisibility="Collapsed"   Grid.Row="1" ItemsSource="{Binding DataView, ElementName=StatusySprawyDomainDataSource}" AutoGenerateColumns="False" Margin="0,2,8,8" ShowGroupPanel="False" Grid.RowSpan="2" AddingNewDataItem="gridViewStatusySprawy_AddingNewDataItem">
    					<telerik:RadGridView.Columns>
    						
    						<local:DateTimePickerColumn MinWidth="20" Header="Od dnia"   DataMemberBinding="{Binding DataStatusu, Mode=TwoWay}" DataFormatString="{}{0:yyyy-MM-dd}" IsFilterable="false"  SortMemberPath="Value" SortingState="Ascending" HeaderTextAlignment="Center"  TextAlignment="Center"  />
								<telerik:GridViewComboBoxColumn EditTriggers="CellClick"  Header="Status" Width="*"  DataMemberBinding="{Binding NazwaStatusu_Id, Mode=TwoWay}" IsFilterable="false"  HeaderTextAlignment="Center" MinWidth="5" TextAlignment="Center"  
							      ItemsSource= "{Binding dictionaryStatusy, Source={StaticResource StatusyList} }"
								SelectedValueMemberPath="Id" 
                                DisplayMemberPath="Nazwa"
							
							/>
							<!--							
                          	<telerik:GridViewComboBoxColumn EditTriggers="CellClick"  Header="Status" Width="*"  DataMemberBinding="{Binding NazwaStatusu_Id, Mode=TwoWay}" IsFilterable="false"  HeaderTextAlignment="Center" MinWidth="5" TextAlignment="Center"  
							     ItemsSource="{Binding dictionaryStatusy, Source={StaticResource StatusyList}}"
								SelectedValueMemberPath="Id" 
                                DisplayMemberPath="Nazwa"
							
							/> -->
    					</telerik:RadGridView.Columns>
							
    				</telerik:RadGridView>
        <telerik:RadDomainDataSource  AutoLoad="False"  Height="0"  Name="StatusySprawyDomainDataSource" QueryName="GetStatusSprawyBySprIdQuery" Width="0" LoadedData="StatusySprawyDomainDataSource_LoadedData" Margin="200,90,200,141" Grid.Row="1">
            <telerik:RadDomainDataSource.DomainContext>
                <my:LexEnaMeritumDomainContext />
        </telerik:RadDomainDataSource.DomainContext>
            <telerik:RadDomainDataSource.QueryParameters>
                <telerik:QueryParameter ParameterName="IdSprawy" />
        </telerik:RadDomainDataSource.QueryParameters>
        </telerik:RadDomainDataSource >
    </Grid>
</UserControl>
