<controls:ChildWindow
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
           xmlns:controls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="LexEnaTrs.ChangePassword"
           Width="400" Height="208" 
           Title="Zmiana hasła">
    <Grid x:Name="LayoutRoot" Margin="2,2,2,-37">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" MinHeight="12" />
        </Grid.RowDefinitions>

        <Button x:Name="CancelButton" Content="Zamknij" Click="CancelButton_Click" Width="75" Height="23" HorizontalAlignment="Right" Margin="0,0,19,29" VerticalAlignment="Bottom" d:LayoutOverrides="Height" />
        <Button x:Name="OKButton" Content="Zmień" Click="OKButton_Click" Width="75" Height="23" HorizontalAlignment="Right" Margin="0,0,98,29" VerticalAlignment="Bottom" d:LayoutOverrides="Height" />
        <PasswordBox Height="23" HorizontalAlignment="Left" Margin="133,34,0,0" x:Name="Oldpwd" Password="{Binding Oldpwd,Mode=TwoWay}" VerticalAlignment="Top" Width="188" />
        <PasswordBox Margin="134,75,57,0" x:Name="Newpwd1" Password="{Binding Newpwd1,Mode=TwoWay}" Height="23" VerticalAlignment="Top" />
        <PasswordBox Height="23" HorizontalAlignment="Left" Margin="134,106,0,0" x:Name="Newpwd2" Password="{Binding Newpwd2,Mode=TwoWay}" VerticalAlignment="Top" Width="187" />
        <TextBlock Height="23" HorizontalAlignment="Left" Margin="45,37,0,0" x:Name="textBlock1" Text="Stare hasło" VerticalAlignment="Top" Width="84" TextAlignment="Right" />
        <TextBlock HorizontalAlignment="Left" Margin="57,79,0,94" x:Name="textBlock1_Copy" Text="Nowe hasło" Width="72" RenderTransformOrigin="0.722,0.435" TextAlignment="Right" />
        <TextBlock HorizontalAlignment="Right" Margin="0,0,252,64" x:Name="textBlock1_Copy1" Width="110" TextAlignment="Right" Height="23" VerticalAlignment="Bottom" ><Run Text="Powtórz n"/><Run Text="owe hasło"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="69,8,0,0" TextWrapping="Wrap" Text="{Binding UsrName}" VerticalAlignment="Top" Width="252" Height="22" FontSize="12" FontWeight="Bold"/>
        
    </Grid>
</controls:ChildWindow>