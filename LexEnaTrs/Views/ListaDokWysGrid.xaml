<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:riaControls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls.DomainServices" xmlns:my="clr-namespace:LexEnaTrs.Web" xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation" x:Class="LexEnaTrs.Views.ListaDokWysGrid"
    mc:Ignorable="d"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:DesignHeight="592" d:DesignWidth="800" Loaded="UserControl_Loaded" FontFamily="Portable User Interface">
    
    <Grid x:Name="LayoutRoot" Background="White">
        
            <telerik:RadDomainDataSource AutoLoad="False" Height="0" PageSize="30"   x:Name="vw_ListadokWysdds" QueryName="GetVw_ListaDokWysParamsQuery" Width="0" LoadedData="vw_ListadokWysdds_LoadedData" LoadingData="vw_ListadokWysdds_LoadingData">
            <telerik:RadDomainDataSource.DomainContext>
                <my:LexEnaMeritumDomainContext />
            </telerik:RadDomainDataSource.DomainContext>
            <telerik:RadDomainDataSource.QueryParameters>
                <telerik:QueryParameter ParameterName="IdUser" />
                <telerik:QueryParameter ParameterName="IdJednostki" />
                <telerik:QueryParameter ParameterName="StatusDok" />
                <telerik:QueryParameter ParameterName="TypDok" />

            </telerik:RadDomainDataSource.QueryParameters>
        </telerik:RadDomainDataSource>
      

        <Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="26"/>
				<RowDefinition/>
				<RowDefinition Height="29"/>
			</Grid.RowDefinitions>


           
		  <Button x:Name="OpenSpr" Content="Otwórz sprawę" HorizontalAlignment="Left" Margin="0" Width="116" VerticalAlignment="Top" Click="OpenSpr_Click"/>
            <Button Content="Edycja" Height="23" HorizontalAlignment="Left" Margin="122,0,0,0" Name="OpenPozew" VerticalAlignment="Top" Width="85" Click="OpenPozew_Click" />
<telerik:RadBusyIndicator x:Name="BusyIndicator" IsBusy="{Binding IsBusy, ElementName=vw_ListadokWysdds}" Grid.Row="1" BusyContent="Przetwarzanie w toku...">
                <telerik:RadGridView ValidatesOnDataErrors="None" IsSynchronizedWithCurrentItem="false"  Grid.Row="1" x:Name="SprawyGridView" AutoGenerateColumns="false" SelectionMode="Multiple" IsReadOnly="True" ItemsSource="{Binding DataView, ElementName=vw_ListadokWysdds}" AutoExpandGroups="True" CanUserFreezeColumns="False" RowIndicatorVisibility="Visible" SelectionChanged="SprawyGridView_SelectionChanged" RowLoaded="SprawyGridView_RowLoaded" Filtered="SprawyGridView_Filtered">
               
                <telerik:RadGridView.Columns>
                    <telerik:GridViewSelectColumn UniqueName="CurrentSprawa" />
                        <telerik:GridViewDataColumn Header="Lp"  IsReadOnly="True" IsFilterable="false" HeaderTextAlignment="Center" TextAlignment="Center" />
                        <telerik:GridViewDataColumn Header="Referent" DataMemberBinding="{Binding Uzytkownik_Nazwa}" IsReadOnly="True" IsFilterable="false" HeaderTextAlignment="Center" MinWidth="5" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="Rodzaj" Header="Nazwa dok." DataMemberBinding="{Binding TypDok, Converter={StaticResource TypDokConverter}}"  IsReadOnly="True" IsFilterable="false" HeaderTextAlignment="Center" MinWidth="20" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DataDok" Header="Data dok." DataMemberBinding="{Binding DataDok, StringFormat=\{0:d\}}"  DataFormatString=" {0:yyyy-MM-dd} " IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="StatusDokum" Header="Status" DataMemberBinding="{Binding StatusDok, Converter={StaticResource StatusDocConverter}}"  IsReadOnly="True"  HeaderTextAlignment="Center" MinWidth="20" TextAlignment="Center" />

                        <telerik:GridViewDataColumn x:Name="SygnaturaColumn" Header="Sygnatura" DataMemberBinding="{Binding sygnatura}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                       
                    <telerik:GridViewDataColumn Header="Dłużnik" DataMemberBinding="{Binding Dluznik}" Width="*" HeaderTextAlignment="Center" MinWidth="150" TextAlignment="Left" />
                    
                    <telerik:GridViewDataColumn Header="Status Sprawy" DataMemberBinding="{Binding NazwaStatusuSprawy}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                    <telerik:GridViewDataColumn Header="Oddział" DataMemberBinding="{Binding Oddzial}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                     <telerik:GridViewDataColumn Header="Paczka EPU" DataMemberBinding="{Binding Paczka}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn Header="Jednostka" DataMemberBinding="{Binding Nazwa_Jednostki}" IsReadOnly="True" IsFilterable="True" HeaderTextAlignment="Center" MinWidth="5" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DataDekret" Header="Data dekret." DataMemberBinding="{Binding DataDekretJednostka, StringFormat=\{0:d\}}"  DataFormatString=" {0:yyyy-MM-dd} " IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />

                    </telerik:RadGridView.Columns>               
                </telerik:RadGridView>
            </telerik:RadBusyIndicator>

            <telerik:RadDataPager x:Name="RadDataPagerSprawy" Source="{Binding DataView, ElementName=vw_ListadokWysdds}" Grid.Row="2" DisplayMode="All" IsTotalItemCountFixed="True" Margin="0,2,0,0" VerticalAlignment="Top" d:LayoutOverrides="Height"  HorizontalAlignment="Left" Width="307"/>
            <Button Content="Dodaj do paczki" Height="23" HorizontalAlignment="Left" Margin="211,0,0,0" Name="AddToPackage" VerticalAlignment="Top" Width="96" Click="AddToPackage_Click" />
            <Button Content="Import XML do e-Sądu" HorizontalAlignment="Left" Margin="515,0,0,0" Name="ImportXML" Visibility="Visible" VerticalAlignment="Top" Width="124" Click="ImportXML_Click" />

            <telerik:RadDropDownButton Content="Raport" Height="23" HorizontalAlignment="Left" Margin="419,0,0,3" Name="ExportRadDDB" Width="92" DataContext="{Binding}">
                <telerik:RadDropDownButton.DropDownContent>
                    <ListBox Name="FormatList" SelectionChanged="FormatList_SelectionChanged">
                        <ListBoxItem Content="Potwierdzenie sald dla zaznaczonych pozycji"  />
                       
                        
                    </ListBox>
                </telerik:RadDropDownButton.DropDownContent>
            </telerik:RadDropDownButton>
            <telerik:RadDropDownButton Content="Pokaż" Height="23" HorizontalAlignment="Left" Margin="313,0,0,3" Name="ShowDocs" Width="100">
                <telerik:RadDropDownButton.DropDownContent>
                    <ListBox Name="ListaAkcji" SelectionChanged="ListaAkcji_SelectionChanged">
                        <ListBoxItem Content="Pokaż dokument" />
                        <ListBoxItem Content="Eksportuj zaznaczone" />
                        <ListBoxItem Content="Eksportuj zaznaczone do XML" />
                        <ListBoxItem Content="Eksportuj informacje o kapitalizacji XML" />
                    </ListBox>
                </telerik:RadDropDownButton.DropDownContent>
            </telerik:RadDropDownButton>
            <telerik:RadDropDownButton Content="Inne operacje" Height="23" HorizontalAlignment="Left" Margin="517,-1,0,4" Name="OtherRadDropDownButton" Width="100">
                <telerik:RadDropDownButton.DropDownContent>
                    <ListBox Name="listBoxOper" SelectionChanged="OperacjeLst_SelectionChanged">
                        <ListBoxItem Content="Zmień datę" />
                        <ListBoxItem Content="Zmień statusy spraw" />
                        <ListBoxItem Content="Zmień statusy spraw i dokumentów" />
                        <ListBoxItem Content="Zmień Pełnomocnika" />
                        <ListBoxItem Content="Zmień strukturę pozwu" />
                    </ListBox>
                </telerik:RadDropDownButton.DropDownContent>
            </telerik:RadDropDownButton>
        </Grid >
    </Grid>
</UserControl>
