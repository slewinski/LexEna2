            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="260*" />
                <RowDefinition Height="29"/>
            </Grid.RowDefinitions>

            <sdk:Label x:Name="label"  HorizontalAlignment="Left" Height="20" Margin="4,2,0,0" VerticalAlignment="Top" Width="134" Content="Data obliczenia stanu" FontWeight="Bold"/>


            <telerik:RadDatePicker x:Name="dtPickStan"    HorizontalAlignment="Left" Margin="154,1,0,0"    Width="110" VerticalAlignment="Top" DateTimeWatermarkContent="Data odsetek"   />
             <CheckBox Content="Format 2" Name="Format" Visibility="Visible"  Margin="274,1,0,0"  IsChecked="False"></CheckBox>

                <telerik:RadButton  x:Name="rbImpFile"  Content="Import arkusza źródłowego"   HorizontalAlignment="Left" Margin="374,1,0,0"    Width="200" VerticalAlignment="Top" Click="rbImpFile_Click"   />
