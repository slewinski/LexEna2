<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:riaControls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls.DomainServices" xmlns:my="clr-namespace:LexEnaTrs.Web" xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation" x:Class="LexEnaTrs.Views.ToolsImportZal"
    mc:Ignorable="d"
    xmlns:local="clr-namespace:LexEnaTrs" 
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:DesignHeight="592" d:DesignWidth="800">

    <Grid x:Name="LayoutRoot" Background="White">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="260*" />
                <RowDefinition Height="29"/>
            </Grid.RowDefinitions>


           
            <telerik:RadButton  x:Name="rbImpFile"  Content="Import zestawienia xlsx"   HorizontalAlignment="Left" Margin="4,1,0,0"    Width="150" VerticalAlignment="Top" Click="rbImpFile_Click"   />
            <telerik:RadButton  x:Name="rbSave"  Content="Zapisz w Wiena" Visibility="Collapsed"   HorizontalAlignment="Left" Margin="158,1,0,0"    Width="150" VerticalAlignment="Top" Click="rbSave_Click"   />
            <telerik:RadButton  x:Name="rbRegister"  Content="Zapisz i zarejestuj w Wiena"  Visibility="Collapsed"  HorizontalAlignment="Left" Margin="312,1,0,0"    VerticalAlignment="Top" Click="rbRegister_Click"   />
          <!--
            <telerik:RadButton  x:Name="rbreport"  Content="Zestawienie pełne"   HorizontalAlignment="Left" Margin="128,1,0,0"  Width="150" VerticalAlignment="Top"  Click="rbreport_Click" />
            <telerik:RadButton  x:Name="rbreportvalid"  Content="Zestawienie weryf."   HorizontalAlignment="Left" Margin="282,1,0,0"  Width="150" VerticalAlignment="Top" Click="rbreportvalid_Click"  />
           -->

            <telerik:RadBusyIndicator x:Name="BusyIndicator"  Grid.Row="1" BusyContent="Przetwarzanie w toku...">
                <telerik:RadGridView ValidatesOnDataErrors="None"  IsSynchronizedWithCurrentItem="false"  Grid.Row="1" x:Name="ZaliczkiGrid" AutoGenerateColumns="false" SelectionMode="Single"    AutoExpandGroups="True" CanUserFreezeColumns="False" RowIndicatorVisibility="Visible"   EnableColumnVirtualization="False" CanUserReorderColumns="False" >

                    <telerik:RadGridView.Columns>
                        <telerik:GridViewDataColumn x:Name="Lp" Header="Lp." DataMemberBinding="{Binding Lp}" HeaderTextAlignment="Center" MinWidth="10" IsReadOnly="True" TextAlignment="Left" />
                        <telerik:GridViewCheckBoxColumn x:Name="Zapis" Header="Zapisać ?" DataMemberBinding="{Binding Zapis, Mode=TwoWay}" HeaderTextAlignment="Center"  MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="Sygnatura" Header="Sygnatura" DataMemberBinding="{Binding Sygnatura}" HeaderTextAlignment="Center" MinWidth="15" IsReadOnly="True" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="Dluznik" Header="Dłużnik" DataMemberBinding="{Binding Dluznik}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" IsReadOnly="True" />
                        <telerik:GridViewDataColumn x:Name="DZaliczki" Header="Data" DataMemberBinding="{Binding DataZaliczki , StringFormat=\{0:yyyy-MM-dd\}}" IsReadOnly="True" HeaderTextAlignment="Center"  MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn  Header="Kwota Zaliczki" TextAlignment="Right"  DataMemberBinding="{Binding Kwota,StringFormat=\{0:c2\},ConverterCulture=pl-PL }" IsFilterable="false" IsReadOnly="True"  HeaderTextAlignment="Center" MinWidth="5"   />
                        <telerik:GridViewDataColumn x:Name="Komentarz" Header="Komentarz" DataMemberBinding="{Binding Uwagi}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" IsReadOnly="True"/>
                        <telerik:GridViewDataColumn x:Name="Errors" Header="Status importu" DataMemberBinding="{Binding Error}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" IsReadOnly="True"/>
                    </telerik:RadGridView.Columns>

                </telerik:RadGridView>
            </telerik:RadBusyIndicator>

           


        </Grid >
    </Grid>
</UserControl>