<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:riaControls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls.DomainServices" xmlns:my="clr-namespace:LexEnaTrs.Web" xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation" x:Class="LexEnaTrs.Views.ToolsExtractPdf"
    mc:Ignorable="d"
    xmlns:local="clr-namespace:LexEnaTrs" 
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:DesignHeight="592" d:DesignWidth="800">

    <Grid x:Name="LayoutRoot" Background="White">
        <telerik:RadDomainDataSource AutoLoad="False" Height="0"  PageSize="1000" x:Name="EkstarakcjaPdfdds" QueryName="GetDOKEKSTRvw_ekstrakcjaByPakietIdQuery" Width="0" LoadingData="EkstarakcjaPdfdds_LoadingData" FontFamily="Portable User Interface">
            <telerik:RadDomainDataSource.DomainContext>
                <my:LexEnaMeritumDomainContext />
            </telerik:RadDomainDataSource.DomainContext>
            <telerik:RadDomainDataSource.QueryParameters>

                <telerik:QueryParameter ParameterName="IdPakiet" />


            </telerik:RadDomainDataSource.QueryParameters>
        </telerik:RadDomainDataSource>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="260*" />
                <RowDefinition Height="29"/>
            </Grid.RowDefinitions>



            <telerik:RadDropDownButton AutoOpenDelay="0:0:0.5" x:Name="rdbImport" CloseOnPopupMouseLeftButtonUp="True" Content="Operacje "  IsOpen="False" HorizontalAlignment="Left" Margin="4,1,0,0"  Width="120" VerticalAlignment="Top" >
                <telerik:RadDropDownButton.DropDownContent>
                    <ListBox Name="OperacjeLst" SelectionChanged="Operacje_SelectionChanged"   >
                        <ListBoxItem Name="ImpFile" Content="Wczytaj listę z arkusza excel" MouseLeftButtonUp="ImpFile_MouseLeftButtonUp"   />
                        <ListBoxItem Name="ExpAll" Content="Eksport wszystkich skanów" MouseLeftButtonUp="ExpAll_MouseLeftButtonUp"   />
                        <ListBoxItem Name="ExpWybranych" Content="Eksport wybranych skanów" MouseLeftButtonUp="ExpSelected_MouseLeftButtonUp"   />
                    </ListBox>
                </telerik:RadDropDownButton.DropDownContent>
            </telerik:RadDropDownButton>
            <telerik:RadButton  x:Name="rbreport"  Content="Zestawienie pełne"   HorizontalAlignment="Left" Margin="128,1,0,0"  Width="150" VerticalAlignment="Top"  Click="rbreport_Click" />
            <telerik:RadButton  x:Name="rbreportvalid"  Content="Zestawienie weryf."   HorizontalAlignment="Left" Margin="282,1,0,0"  Width="150" VerticalAlignment="Top" Click="rbreportvalid_Click"  />



            <telerik:RadBusyIndicator x:Name="BusyIndicator" IsBusy="{Binding IsBusy, ElementName=EkstarakcjaPdfdds}" Grid.Row="1" BusyContent="Przetwarzanie w toku...">
                <telerik:RadGridView ValidatesOnDataErrors="None" IsSynchronizedWithCurrentItem="false"  Grid.Row="1" x:Name="SprawyGridView" AutoGenerateColumns="false" SelectionMode="Multiple"  IsReadOnly="True" ItemsSource="{Binding DataView, ElementName=EkstarakcjaPdfdds}" AutoExpandGroups="True" CanUserFreezeColumns="False" RowIndicatorVisibility="Visible" SelectionChanged="SprawyGridView_SelectionChanged"   EnableColumnVirtualization="False" CanUserReorderColumns="False" Filtered="SprawyGridView_Filtered">

                    <telerik:RadGridView.Columns>
                        <telerik:GridViewDataColumn x:Name="Lp" Header="Lp." DataMemberBinding="{Binding id}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="Sygnatura" Header="Sygnatura" DataMemberBinding="{Binding sygnatura}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="Dokument" Header="Dokument" DataMemberBinding="{Binding nazwa}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />
                        <telerik:GridViewDataColumn x:Name="Ddokumentu" Header="Data dokumentu" DataMemberBinding="{Binding d_dok, StringFormat=\{0:yyyy-MM-dd\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="Kancelaria" Header="Kancelaria" DataMemberBinding="{Binding kancelaria}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Left" />

                    </telerik:RadGridView.Columns>

                </telerik:RadGridView>
            </telerik:RadBusyIndicator>

            <telerik:RadDataPager x:Name="RadDataPagerSprawy" Source="{Binding DataView, ElementName=EkstarakcjaPdfdds}" Grid.Row="2" DisplayMode="All" IsTotalItemCountFixed="True" Margin="0,2,0,0" VerticalAlignment="Top" d:LayoutOverrides="Height"  HorizontalAlignment="Right" Width="307"/>
            <sdk:Label x:Name="Rcount" HorizontalAlignment="Right" Height="25" Margin="0,1,0,0" VerticalAlignment="Center" Width="103" Content=""/>



        </Grid >
    </Grid>
</UserControl>