<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:riaControls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls.DomainServices" xmlns:my="clr-namespace:LexEnaTrs.Web" xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation" x:Class="LexEnaTrs.Views.Tools1"
    mc:Ignorable="d"
    xmlns:local="clr-namespace:LexEnaTrs" 
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:DesignHeight="592" d:DesignWidth="800">

    <Grid x:Name="LayoutRoot" Background="White">

        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="249*" />
                <RowDefinition Height="28*" />
                <RowDefinition Height="260*" />
                <RowDefinition Height="29"/>
            </Grid.RowDefinitions>
           

     
            <telerik:RadDropDownButton AutoOpenDelay="0:0:0.5" x:Name="rdbImport" CloseOnPopupMouseLeftButtonUp="True" Content="Operacje "  IsOpen="False" HorizontalAlignment="Left" Margin="4,1,0,0"  Width="120" VerticalAlignment="Top">
                <telerik:RadDropDownButton.DropDownContent>
                    <ListBox Name="Narzędzia" SelectionChanged="Narzędzia_SelectionChanged"   >
                        <ListBoxItem Name="SpadyEpu" Content="Sprawy przekazane z e-sądu" MouseLeftButtonUp="SpadyEpu_MouseLeftButtonUp"   />
                     
                    </ListBox>
                </telerik:RadDropDownButton.DropDownContent>
            </telerik:RadDropDownButton>

         
        </Grid >
    </Grid>
</UserControl>
