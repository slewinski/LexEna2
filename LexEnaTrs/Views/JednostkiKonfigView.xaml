<UserControl x:Class="LexEnaTrs.Views.JednostkiKonfigView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation" xmlns:my="clr-namespace:LexEnaTrs.Web"
			   xmlns:local="clr-namespace:LexEnaTrs"
			   >
    <UserControl.Resources>
        <DataTemplate x:Key="JednostkaWindykFormTemplate" >
            <Grid Margin="0">
                <Grid Margin="1,1,1,1">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="100" />
                        <RowDefinition Height="*" />

                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50" />
                            <RowDefinition Height="50" />

                        </Grid.RowDefinitions>



                        <telerik:DataFormDataField Margin="-80,0,0,0" Grid.Row="0" Grid.Column="1"  DataMemberBinding="{Binding Nazwa, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Top"  Width="300"/>
                        <TextBlock HorizontalAlignment="Right" Margin="0,5,0,0" Grid.Row="0" Grid.Column="0"  TextWrapping="Wrap" Text="Nazwa jednostki" VerticalAlignment="Top"/>

                        <telerik:DataFormComboBoxField  DataMemberBinding = "{Binding TypJednostki, Mode=TwoWay}" Grid.Row="1" Grid.Column="1"  
				ItemsSource="{Binding rodzajeJednostek, Source={StaticResource SlownikRodzajeJednostek}}" DisplayMemberPath="Nazwa" SelectedValuePath="Numer" x:Name = "TypJednostki" ToolTipService.ToolTip="Wybierz typ jednostki"  Margin="0,0,0,0" d:LayoutOverrides="GridBox" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <TextBlock HorizontalAlignment="Right"  Grid.Row="1" Grid.Column="0"   Margin="0,5,0,0" TextWrapping="Wrap" Text="Typ jednostki" VerticalAlignment="Top"/>
                    </Grid>
                    
                    <Grid Grid.Row="1" Width="550"  HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"  />
                            <RowDefinition Height="50" />
                            <RowDefinition Height="50" />
                            <RowDefinition Height="50" />
                            <RowDefinition Height="50" />
                            <RowDefinition Height="50" />
                            <RowDefinition Height="50" />
                            <RowDefinition Height="50" />
                            <RowDefinition Height="50" />
                            <RowDefinition Height="50" />
                            <RowDefinition Height="50" />
                            
                            
                            
                        </Grid.RowDefinitions>

                        <Border BorderBrush="Black" BorderThickness="2" Grid.Row="0" Grid.Column="0"/>
                        <Border BorderBrush="Black" BorderThickness="2" Grid.Row="0" Grid.Column="1"/>
                        <Border BorderBrush="Black" BorderThickness="2" Grid.Row="0" Grid.Column="2"/>
                        <Border BorderBrush="Black" BorderThickness="2" Grid.Row="0" Grid.Column="3"/>


                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="1" Grid.Column="0"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="1" Grid.Column="1"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="1" Grid.Column="2"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="1" Grid.Column="3"/>


                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="2" Grid.Column="0"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="2" Grid.Column="1"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="2" Grid.Column="2"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="2" Grid.Column="3"/>


                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="3" Grid.Column="0"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="3" Grid.Column="1"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="3" Grid.Column="2"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="3" Grid.Column="3"/>

                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="4" Grid.Column="0"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="4" Grid.Column="1"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="4" Grid.Column="2"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="4" Grid.Column="3"/>

                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="5" Grid.Column="0"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="5" Grid.Column="1"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="5" Grid.Column="2"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="5" Grid.Column="3"/>

                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="6" Grid.Column="0"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="6" Grid.Column="1"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="6" Grid.Column="2"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="6" Grid.Column="3"/>

                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="7" Grid.Column="0"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="7" Grid.Column="1"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="7" Grid.Column="2"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="7" Grid.Column="3"/>

                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="8" Grid.Column="0"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="8" Grid.Column="1"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="8" Grid.Column="2"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="8" Grid.Column="3"/>

                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="9" Grid.Column="0"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="9" Grid.Column="1"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="9" Grid.Column="2"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="9" Grid.Column="3"/>

                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="10" Grid.Column="0"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="10" Grid.Column="1"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="10" Grid.Column="2"/>
                        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="10" Grid.Column="3"/>


                        <TextBlock HorizontalAlignment="Center" FontWeight="Bold" Margin="0,5,0,0" Grid.Row="0" Grid.Column="0"  TextWrapping="Wrap" Text="Działanie" VerticalAlignment="Top"/>
                        
                        <TextBlock HorizontalAlignment="Center" FontWeight="Bold" Margin="0,5,0,0" Grid.Row="0" Grid.Column="1"  TextWrapping="Wrap" Text="Dni na wykonanie" VerticalAlignment="Top"/>
                     
                           
                                <TextBlock HorizontalAlignment="Center" FontWeight="Bold" Margin="10,5,0,0" Grid.Row="0" Grid.Column="2"  TextWrapping="Wrap" Text="Dni na wyk. 1 mln. " VerticalAlignment="Top"/>
                  
                      
                                    <TextBlock HorizontalAlignment="Left" FontWeight="Bold" Margin="10,5,0,0" Grid.Row="0" Grid.Column="3"  TextWrapping="Wrap" Text="Dni na publikację" VerticalAlignment="Top"/>
                     
                      
                                        <TextBlock HorizontalAlignment="Left" FontWeight="Bold" Margin="10,5,0,0" Grid.Row="0" Grid.Column="3"  TextWrapping="Wrap" Text="Dni na publikację" VerticalAlignment="Top"/>
                      
                        <TextBlock HorizontalAlignment="Right" TextAlignment="Right" FontWeight="Bold" Margin="0,5,0,10" Grid.Row="1" Grid.Column="0"  TextWrapping="Wrap" Text="Pozew w EPU" VerticalAlignment="Top"/>
                        <TextBlock HorizontalAlignment="Right"  TextAlignment="Right" FontWeight="Bold" Margin="0,5,0,10" Grid.Row="2" Grid.Column="0"  TextWrapping="Wrap" Text="Pozew tradyc./zawezw. do próby ugodowej" VerticalAlignment="Top"/>
                        <TextBlock HorizontalAlignment="Right"  TextAlignment="Right" FontWeight="Bold" Margin="0,5,0,10" Grid.Row="3" Grid.Column="0"  TextWrapping="Wrap" Text="Nakaz/wyrok w EPU" VerticalAlignment="Top"/>
                        <TextBlock HorizontalAlignment="Right"  TextAlignment="Right" FontWeight="Bold" Margin="0,5,0,10" Grid.Row="4" Grid.Column="0"  TextWrapping="Wrap" Text="Nakaz/wyrok tradycyjny" VerticalAlignment="Top"/>
                        <TextBlock HorizontalAlignment="Right"  TextAlignment="Right" FontWeight="Bold" Margin="0,5,0,10" Grid.Row="5" Grid.Column="0"  TextWrapping="Wrap" Text="Tytuł wykonawczy w EPU" VerticalAlignment="Top"/>
                        <TextBlock HorizontalAlignment="Right"  TextAlignment="Right" FontWeight="Bold" Margin="0,5,0,10" Grid.Row="6" Grid.Column="0"  TextWrapping="Wrap" Text="Tytuł wykonawczy tradycyjny" VerticalAlignment="Top"/>
                        <TextBlock HorizontalAlignment="Right"  TextAlignment="Right" FontWeight="Bold" Margin="0,5,0,10" Grid.Row="7" Grid.Column="0"  TextWrapping="Wrap" Text="Informacja o wniesionym sprzeciwie" VerticalAlignment="Top"/>
                        <TextBlock HorizontalAlignment="Right"  TextAlignment="Right" FontWeight="Bold" Margin="0,5,0,10" Grid.Row="8" Grid.Column="0"  TextWrapping="Wrap" Text="Wnioski Egzekucyjne w EPU" VerticalAlignment="Top"/>
                        <TextBlock HorizontalAlignment="Right"  TextAlignment="Right" FontWeight="Bold" Margin="0,5,0,10" Grid.Row="9" Grid.Column="0"  TextWrapping="Wrap" Text="Wnioski Egzekucyjne tradycyjne" VerticalAlignment="Top"/>
                        <TextBlock HorizontalAlignment="Right"  TextAlignment="Right" FontWeight="Bold" Margin="0,5,0,10" Grid.Row="10" Grid.Column="0"  TextWrapping="Wrap" Text="Korespondencja komornicza" VerticalAlignment="Top"/>

                        <telerik:DataFormDataField Margin="0,0,0,0" Grid.Row="1" Grid.Column="1" Width="120"  DataMemberBinding="{Binding PozewEPU, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Top" />
                        <telerik:DataFormDataField Margin="0,0,0,0" Grid.Row="1" Grid.Column="2" Width="120"  DataMemberBinding="{Binding PozewEPUBig, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Top" />
                        <telerik:DataFormDataField Margin="0,0,0,0" Grid.Row="1" Grid.Column="3" Width="120"  DataMemberBinding="{Binding PozewEPUbuf, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Top" />

                        <telerik:DataFormDataField Margin="0,0,0,0" Grid.Row="2" Grid.Column="1" Width="120"  DataMemberBinding="{Binding Pozew, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Top" />
                        <telerik:DataFormDataField Margin="0,0,0,0" Grid.Row="2" Grid.Column="2" Width="120"  DataMemberBinding="{Binding PozewBig, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Top" />
                        <telerik:DataFormDataField Margin="0,0,0,0" Grid.Row="2" Grid.Column="3" Width="120"  DataMemberBinding="{Binding Pozewbuf, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Top" />

                        <telerik:DataFormDataField Margin="0,0,0,0" Grid.Row="3" Grid.Column="3" Width="120"  DataMemberBinding="{Binding NakazEPUbuf, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Top" />
                        <telerik:DataFormDataField Margin="0,0,0,0" Grid.Row="4" Grid.Column="3" Width="120"  DataMemberBinding="{Binding Nakazbuf, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Top" />

                        <telerik:DataFormDataField Margin="0,0,0,0" Grid.Row="5" Grid.Column="3" Width="120"  DataMemberBinding="{Binding TytulEPUbuf, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Top" />
                        <telerik:DataFormDataField Margin="0,0,0,0" Grid.Row="6" Grid.Column="3" Width="120"  DataMemberBinding="{Binding Tytulbuf, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Top" />
                        <telerik:DataFormDataField Margin="0,0,0,0" Grid.Row="7" Grid.Column="3" Width="120"  DataMemberBinding="{Binding Sprzeciwbuf, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Top" />
                
                        <telerik:DataFormDataField Margin="0,0,0,0" Grid.Row="8" Grid.Column="1" Width="120"  DataMemberBinding="{Binding WnioskiEgzEPU, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Top" />
                        <telerik:DataFormDataField Margin="0,0,0,0" Grid.Row="8" Grid.Column="2" Width="120"  DataMemberBinding="{Binding WnioskiEgzEPUBig, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Top" />
                        <telerik:DataFormDataField Margin="0,0,0,0" Grid.Row="8" Grid.Column="3" Width="120"  DataMemberBinding="{Binding WnioskiEgzBuf, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Top" />

                        <telerik:DataFormDataField Margin="0,0,0,0" Grid.Row="9" Grid.Column="1" Width="120"  DataMemberBinding="{Binding Wnioski, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Top" />
                        <telerik:DataFormDataField Margin="0,0,0,0" Grid.Row="9" Grid.Column="2" Width="120"  DataMemberBinding="{Binding WnioskiEgzBig, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Top" />
                        <telerik:DataFormDataField Margin="0,0,0,0" Grid.Row="9" Grid.Column="3" Width="120"  DataMemberBinding="{Binding Wnioskibuf, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Top" />

                        <telerik:DataFormDataField Margin="0,0,0,0" Grid.Row="10" Grid.Column="3" Width="120"  DataMemberBinding="{Binding KorespKomobuf, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Top" />


                    </Grid>       

                </Grid>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="LayoutRoot" Background="White" Height="Auto">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="474" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <telerik:RadDomainDataSource AutoLoad="True" Height="0"   x:Name="JednostkiWindykacjidds" QueryName="GetJednostkaWindykacjiQuery" Width="0" Grid.Column="1" >
            <telerik:RadDomainDataSource.DomainContext>
                <my:LexEnaMeritumDomainContext />
            </telerik:RadDomainDataSource.DomainContext>

        </telerik:RadDomainDataSource>
        <telerik:RadGridView HorizontalAlignment="Left" Name="JednostkiWindykacjiGridView" ItemsSource="{Binding DataView,ElementName=JednostkiWindykacjidds}" IsReadOnly="True" VerticalAlignment="Top"  IsFilteringAllowed="False" IsEnabled="True" AutoGenerateColumns="False" CanUserSortColumns="False" ShowGroupPanel="False" Width="470">
            <telerik:RadGridView.Columns>
                <telerik:GridViewDataColumn  Header="Typ" Width="200" DataMemberBinding="{Binding TypJednostki,Converter={StaticResource TypJednostkiConverter}}" IsFilterable="false"  HeaderTextAlignment="Center" MinWidth="5" TextAlignment="Center" />
                <telerik:GridViewDataColumn  Header="Nazwa" Width="*" DataMemberBinding="{Binding Nazwa}" IsFilterable="false"  HeaderTextAlignment="Center" MinWidth="5" TextAlignment="Center"  />
            </telerik:RadGridView.Columns>
        </telerik:RadGridView>
        <telerik:RadDataForm Name="JednostkiDataForm" ItemsSource="{Binding DataView,ElementName=JednostkiWindykacjidds}" AutoGenerateFields="False" CancelButtonContent="Anuluj" Grid.Column="1" Margin="0,0,0,0"
                             ReadOnlyTemplate="{StaticResource JednostkaWindykFormTemplate}"
                             NewItemTemplate="{StaticResource JednostkaWindykFormTemplate}"
                             EditTemplate="{StaticResource JednostkaWindykFormTemplate}"  EditEnded="JednostkiDataForm_EditEnded" AddedNewItem="JednostkiDataForm_AddedNewItem"  DeletingItem="JednostkiDataForm_DeletingItem" />
    </Grid>
</UserControl>
