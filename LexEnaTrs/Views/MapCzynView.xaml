<UserControl x:Class="LexEnaTrs.Views.MapCzynView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d" xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation" xmlns:my="clr-namespace:LexEnaTrs.Web"
			   xmlns:local="clr-namespace:LexEnaTrs" Loaded="UserControl_Loaded">
	<UserControl.Resources>
		<DataTemplate x:Key="MultiLineTemplate">
            <TextBox TextWrapping="Wrap" Text="{Binding Tresc,Mode=TwoWay}" /> 
        </DataTemplate>
        <DataTemplate x:Key="SlownikiFormTemplate" >
            <Grid Margin="0" Height="300" Width="650">

                <telerik:DataFormComboBoxField Label = "Akcja" DataMemberBinding="{Binding obsluga, Mode=TwoWay}"  ItemsSource= "{Binding TypAkcjiDokSlownik, Source={StaticResource SlownikAutoAkcjiDok}}"  DisplayMemberPath="Nazwa" SelectedValuePath="Numer" Margin="0,39,0,0" VerticalAlignment="Top" />

                <telerik:DataFormComboBoxField Margin="0,8,0,0" Label="Oznaczenie czynności" DataMemberBinding="{Binding nazwaDok, Mode=TwoWay}"   ItemsSource= "{Binding NazwaDokWiena, Source={StaticResource SlownikWienaDok}}"  DisplayMemberPath="Nazwa" SelectedValuePath="Nazwa"    VerticalAlignment="Top"/>
              
               
            </Grid>
        </DataTemplate>
		
		 <DataTemplate x:Key="SlownikiROFormTemplate" >
            <Grid Margin="0" Height="300" Width="650">

                <telerik:DataFormComboBoxField Label = "Akcja" DataMemberBinding="{Binding obsluga, Mode=TwoWay}"  ItemsSource= "{Binding TypAkcjiDokSlownik, Source={StaticResource SlownikAutoAkcjiDok}}"  DisplayMemberPath="Nazwa" SelectedValuePath="Numer" Margin="0,39,0,0" VerticalAlignment="Top" />

                <telerik:DataFormDataField Margin="0,8,0,0" Label="Oznaczenie czynności" DataMemberBinding="{Binding nazwaDok, Mode=TwoWay}" VerticalAlignment="Top"/>


            </Grid>
        </DataTemplate>
    </UserControl.Resources>
    
    <Grid x:Name="LayoutRoot" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="670*" />
        </Grid.ColumnDefinitions>


        <telerik:RadDomainDataSource AutoLoad="False" Height="0"   x:Name="Slownikidds" QueryName="GetMapDokKomQuery" Width="0" Grid.Column="1" >
            <telerik:RadDomainDataSource.DomainContext>
                <my:LexEnaMeritumDomainContext />
            </telerik:RadDomainDataSource.DomainContext>
           
        </telerik:RadDomainDataSource>

        <telerik:RadGridView HorizontalAlignment="Left" Name="SlownikiDataGrid" Grid.Column="0" ItemsSource="{Binding DataView,ElementName=Slownikidds}" IsReadOnly="True" VerticalAlignment="Top"  IsFilteringAllowed="False" IsEnabled="True" AutoGenerateColumns="False" CanUserSortColumns="False" ShowGroupPanel="False" Margin="0,0,0,0">
            <telerik:RadGridView.Columns>
                
                <telerik:GridViewDataColumn  Header="Czynność komornicza" Width="*" DataMemberBinding="{Binding nazwaDok}" IsFilterable="false"  HeaderTextAlignment="Center" MinWidth="5" TextAlignment="Center"  />
				
            </telerik:RadGridView.Columns>
        </telerik:RadGridView>
       
	    <telerik:RadDataForm Name="SlownikiDataForm" VerticalAlignment="Top" ItemsSource="{Binding DataView,ElementName=Slownikidds}" AutoGenerateFields="False" CancelButtonContent="Anuluj" Grid.Column="1" 
                             ReadOnlyTemplate="{StaticResource SlownikiROFormTemplate}" HorizontalAlignment="Left"
                             NewItemTemplate="{StaticResource SlownikiFormTemplate}"
                             EditTemplate="{StaticResource SlownikiFormTemplate}" DeletingItem="SlownikiDataForm_DeletingItem"  AddedNewItem="SlownikiataForm_AddedNewItem" EditEnded="SlownikiDataForm_EditEnded" >

        </telerik:RadDataForm>
		
    </Grid>
</UserControl>
