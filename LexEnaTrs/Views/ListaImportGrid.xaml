<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:riaControls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls.DomainServices" xmlns:my="clr-namespace:LexEnaTrs.Web" xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation" x:Class="LexEnaTrs.Views.ListaImportGrid"
    mc:Ignorable="d"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:DesignHeight="592" d:DesignWidth="800" Loaded="UserControl_Loaded">

    <Grid x:Name="LayoutRoot" Background="White">

        <telerik:RadDomainDataSource AutoLoad="False" Height="0" PageSize="40"   x:Name="vw_ListImportsdds" QueryName="GetVw_ListaImportsParamsQuery" Width="0" LoadedData="vw_ListImportsdds_LoadedData" LoadingData="vw_ListaImportsdds_LoadingData">
            <telerik:RadDomainDataSource.DomainContext>
                <my:LexEnaMeritumDomainContext />
            </telerik:RadDomainDataSource.DomainContext>
            <telerik:RadDomainDataSource.QueryParameters>
                <telerik:QueryParameter ParameterName="IdJednostki" />
                <telerik:QueryParameter ParameterName="ImpTyp" />
            </telerik:RadDomainDataSource.QueryParameters>
            
        </telerik:RadDomainDataSource>
        <telerik:RadDomainDataSource AutoLoad="False" Height="0"  PageSize="400" x:Name="vw_ImportDetailsdds" QueryName="GetVw_ImportDetailsByImportIdQuery" Width="0" LoadingData="vw_ImportDetailsdds_LoadingData">
            <telerik:RadDomainDataSource.DomainContext>
                <my:LexEnaMeritumDomainContext />
            </telerik:RadDomainDataSource.DomainContext>
            <telerik:RadDomainDataSource.QueryParameters>

                <telerik:QueryParameter ParameterName="Import_Id" />


            </telerik:RadDomainDataSource.QueryParameters>
        </telerik:RadDomainDataSource>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="249*" />
                <RowDefinition Height="28*" />
                <RowDefinition Height="260*" />
                <RowDefinition Height="29"/>
            </Grid.RowDefinitions>



            <Button x:Name="ImportFile" Content="Importuj XML" HorizontalAlignment="Left" Margin="4,0,0,0" VerticalAlignment="Top" Click="ImportFile_Click"/>
            <telerik:RadBusyIndicator x:Name="BusyIndicator" IsBusy="{Binding IsBusy, ElementName=vw_ListImportsdds}" Grid.Row="1" BusyContent="Przetwarzanie w toku...">
                <telerik:RadGridView ValidatesOnDataErrors="None" IsSynchronizedWithCurrentItem="false"  Grid.Row="1" x:Name="SprawyGridView" AutoGenerateColumns="false" SelectionMode="Single" IsReadOnly="True" ItemsSource="{Binding DataView, ElementName=vw_ListImportsdds}" AutoExpandGroups="True" CanUserFreezeColumns="False" RowIndicatorVisibility="Visible" SelectionChanged="SprawyGridView_SelectionChanged" RowLoaded="SprawyGridView_RowLoaded" FilteringMode="FilterRow" EnableColumnVirtualization="False" CanUserReorderColumns="False">
                    <telerik:RadContextMenu.ContextMenu>
                        <telerik:RadContextMenu x:Name="GridContextMenu">
                            <telerik:RadMenuItem Header="Pokaż szczegóły" Click="DetailsItem_Click"  />
                            <telerik:RadMenuItem Header="Szukaj" Click="SearchItem_Click"  />
                        </telerik:RadContextMenu>
                    </telerik:RadContextMenu.ContextMenu>

                    <telerik:RadGridView.Columns>



                        <telerik:GridViewDataColumn x:Name="DataI" Header="Data importu" DataMemberBinding="{Binding DataTransferu, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn Header="Jednostka" DataMemberBinding="{Binding NazwaJednostki}" IsReadOnly="True" IsFilterable="True" HeaderTextAlignment="Center" MinWidth="5" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="ImpEks" Header="Imp/Eksp" DataMemberBinding="{Binding ImExpDescr}"  IsReadOnly="True" IsFilterable="true" HeaderTextAlignment="Center" MinWidth="20" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="Rodzaj" Header="Nazwa dok." DataMemberBinding="{Binding Zawartosc}"  IsReadOnly="True" IsFilterable="true" HeaderTextAlignment="Center" MinWidth="20" TextAlignment="Center" />
                        <telerik:GridViewDataColumn Header="Nazwa zbioru" DataMemberBinding="{Binding NazwaZbioru}" Width="*" HeaderTextAlignment="Center" MinWidth="150" TextAlignment="Left" />

                        <telerik:GridViewDataColumn x:Name="StatusOper" Header="Status" DataMemberBinding="{Binding Operacja}"  IsReadOnly="True"  HeaderTextAlignment="Center" MinWidth="20" TextAlignment="Center" />

                        <telerik:GridViewDataColumn x:Name="OpisOper" Header="Opis operacji" DataMemberBinding="{Binding OpisOperacji}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />

                        <telerik:GridViewDataColumn Header="Liczba pozycji" DataMemberBinding="{Binding LPoz}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn Header="Operator" DataMemberBinding="{Binding UserName}" IsReadOnly="True" IsFilterable="True" HeaderTextAlignment="Center" MinWidth="5" TextAlignment="Center" />

                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
            </telerik:RadBusyIndicator>

            <telerik:RadDataPager x:Name="RadDataPagerSprawy" Source="{Binding DataView, ElementName=vw_ListImportsdds}" Grid.Row="2" DisplayMode="All" IsTotalItemCountFixed="True" Margin="0,2,0,0" VerticalAlignment="Top" d:LayoutOverrides="Height"  HorizontalAlignment="Right" Width="307"/>

            <telerik:RadBusyIndicator x:Name="BusyIndicator2" IsBusy="{Binding IsBusy, ElementName=vw_ImportDetailsdds}" Grid.Row="3" BusyContent="Odczyt danych proszę czekać...">
                <telerik:RadGridView ValidatesOnDataErrors="None" FilteringMode="FilterRow" IsSynchronizedWithCurrentItem="false"  Grid.Row="3" x:Name="ImportDetailsGridView" AutoGenerateColumns="false" SelectionMode="Multiple" IsReadOnly="True" ItemsSource="{Binding DataView, ElementName=vw_ImportDetailsdds}" AutoExpandGroups="True" CanUserFreezeColumns="False" RowIndicatorVisibility="Visible" RowLoaded="ImportDetailsGridView_RowLoaded">

                    <telerik:RadGridView.Columns>

                        <telerik:GridViewDataColumn x:Name="Lp" Header="Lp"  IsReadOnly="True" DataMemberBinding="{Binding Row}"  IsFilterable="false" HeaderTextAlignment="Center"  TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="SygnaturaColumn" Header="Sygnatura" DataMemberBinding="{Binding Sygnatura}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="DataImpDet" Header="Data importu" DataMemberBinding="{Binding DataImportu, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" IsReadOnly="True" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="StatusPperacji" Header="Status operacji" DataMemberBinding="{Binding LevelDescr}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="OpisBledu" Header="Opis błędu" DataMemberBinding="{Binding ErrDescr}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="KodBledu" Header="Kod błędu" DataMemberBinding="{Binding Code}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />

                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
            </telerik:RadBusyIndicator>

            <telerik:RadDataPager x:Name="RadDataPagerImportDetails" Source="{Binding DataView, ElementName=vw_ImportDetailsdds}" Grid.Row="4" DisplayMode="All" IsTotalItemCountFixed="True" Margin="493,1,0,0" VerticalAlignment="Top" d:LayoutOverrides="Height"  HorizontalAlignment="Right" Width="307"/>
            <Button x:Name="rbImportXLS" Content="Importuj XLSX" Grid.Row="0" HorizontalAlignment="Left"  Margin="95,0,0,0" VerticalAlignment="Top" Click="rbImportXLS_Click"/>
            <Button x:Name="btExport" Content="Eksport do XLS" HorizontalAlignment="Left" Margin="10,4,0,0" Grid.Row="2" VerticalAlignment="Top" Width="94" Click="btExport_Click"/>

        </Grid >
    </Grid>
</UserControl>
