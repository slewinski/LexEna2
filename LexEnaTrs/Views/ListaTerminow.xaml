<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:riaControls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls.DomainServices" xmlns:my="clr-namespace:LexEnaTrs.Web" xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation" x:Class="LexEnaTrs.Views.ListaTerminow"
    mc:Ignorable="d"
    d:DesignHeight="592" d:DesignWidth="800" Loaded="UserControl_Loaded">
    
    <Grid x:Name="LayoutRoot" Background="White">
        
            <telerik:RadDomainDataSource AutoLoad="False" Height="0" PageSize="30"  x:Name="vw_ListaTerminowdds" QueryName="GetVw_ListaTerminowParamsQuery" Width="0" LoadedData="vw_ListaSprawdds_LoadedData" LoadingData="vw_ListaSprawdds_LoadingData">
                <telerik:RadDomainDataSource.DomainContext>
                    <my:LexEnaMeritumDomainContext />
                </telerik:RadDomainDataSource.DomainContext>
                <telerik:RadDomainDataSource.QueryParameters>
                    <telerik:QueryParameter ParameterName="IdUser" />
                    <telerik:QueryParameter ParameterName="IdJednostki" />
                    <telerik:QueryParameter ParameterName="Status" />
                    <telerik:QueryParameter ParameterName="dzien" />

                </telerik:RadDomainDataSource.QueryParameters>
            </telerik:RadDomainDataSource>
        <Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="26"/>
				<RowDefinition/>
				<RowDefinition Height="29"/>
			</Grid.RowDefinitions>


           
		  <Button x:Name="OpenSpr" Content="Otwórz sprawę" HorizontalAlignment="Left" Margin="0" Width="116" VerticalAlignment="Top" Click="OpenSpr_Click"/>
            <telerik:RadBusyIndicator x:Name="BusyIndicator" IsBusy="{Binding IsBusy, ElementName=vw_ListaTerminowdds}" Grid.Row="1" BusyContent="Przetwarzanie w toku...">
                <telerik:RadGridView  IsSynchronizedWithCurrentItem="false"  Grid.Row="1" x:Name="SprawyGridView" AutoGenerateColumns="false" SelectionMode="Multiple"  IsReadOnly="True" ItemsSource="{Binding DataView, ElementName=vw_ListaTerminowdds}" AutoExpandGroups="True" CanUserFreezeColumns="False" RowIndicatorVisibility="Visible" SelectionChanged="SprawyGridView_SelectionChanged" RowLoaded="SprawyGridView_RowLoaded">
               
                <telerik:RadGridView.Columns>
                    <telerik:GridViewSelectColumn UniqueName="CurrentSprawa" />
                        <telerik:GridViewDataColumn Header="Lp" IsReadOnly="True"  HeaderTextAlignment="Center" MinWidth="5" TextAlignment="Center" />
                        <telerik:GridViewDataColumn Header="Referent" DataMemberBinding="{Binding Uzytkownik_Nazwa}" IsReadOnly="True"  HeaderTextAlignment="Center" MinWidth="5" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="SygnaturaColumn" Header="Sygnatura" DataMemberBinding="{Binding sygnatura}" HeaderTextAlignment="Center" MinWidth="15" TextAlignment="Center" />
                        <telerik:GridViewDataColumn Header="Dłużnik" DataMemberBinding="{Binding Dluznik}" Width="*" HeaderTextAlignment="Center" MinWidth="150" TextAlignment="Left" />
                    <telerik:GridViewDataColumn Header="Zdarzenie" DataMemberBinding="{Binding Nazwa}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn Header="Opis" DataMemberBinding="{Binding Opis}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
                        <telerik:GridViewDataColumn Header="Oddział" DataMemberBinding="{Binding Oddzial}" HeaderTextAlignment="Center" MinWidth="10" TextAlignment="Center" />
               
                   
                     
                    <telerik:GridViewDataColumn Header="Jednostka" DataMemberBinding="{Binding Nazwa_Jednostki}" IsReadOnly="True" IsFilterable="false" HeaderTextAlignment="Center" MinWidth="5" TextAlignment="Center" />
                        <telerik:GridViewDataColumn Header="Termin upływa" DataMemberBinding="{Binding DataDoWykonania, StringFormat=\{0:d\}}"  DataFormatString=" {0:yyyy-MM-dd} " IsReadOnly="True" IsFilterable="false" HeaderTextAlignment="Center" MinWidth="5" TextAlignment="Center" />
                        <telerik:GridViewDataColumn x:Name="Statussprawy" Header="Status spr." DataMemberBinding="{Binding NazwaStatusuSprawy}"  DataFormatString=" {0:yyyy-MM-dd} " IsReadOnly="True" IsFilterable="false" HeaderTextAlignment="Center" MinWidth="20" TextAlignment="Center" />
                                                
                    </telerik:RadGridView.Columns>               
                </telerik:RadGridView>
            </telerik:RadBusyIndicator>

            <telerik:RadDataPager x:Name="RadDataPagerSprawy" Source="{Binding DataView, ElementName=vw_ListaTerminowdds}" Grid.Row="2" DisplayMode="All" IsTotalItemCountFixed="True" Margin="0,2,0,0" VerticalAlignment="Top" d:LayoutOverrides="Height"  HorizontalAlignment="Left" Width="307"/>
            <telerik:RadDropDownButton Content="Dokument" Height="23" HorizontalAlignment="Left" Margin="122,-1,0,4" Name="MakeDok" Width="100">
                <telerik:RadDropDownButton.DropDownContent>
                    <ListBox Name="ListaAkcji" SelectionChanged="ListaAkcji_SelectionChanged">
                        <ListBoxItem Content="Pismo" />
                        <ListBoxItem Content="Wniosek" />
                        <ListBoxItem Content="Uzupełnienie adresu" />
                        <ListBoxItem Content="Uzupełnienie braków" />
                        <ListBoxItem Content="Rezygnacja z pełnomocnictwa" />
                        <ListBoxItem Content="Zgłoszenie pełnomocnika do sprawy" />
                        <ListBoxItem Content="Dokumentacja inicjująca postępowanie" />
                    </ListBox>
                </telerik:RadDropDownButton.DropDownContent>
            </telerik:RadDropDownButton>
        </Grid >
    </Grid>
</UserControl>
