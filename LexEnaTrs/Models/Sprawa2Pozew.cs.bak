                                        _odsetki.DataOd = new DateTime(2000, 1, 1);
                                    }
                                    if (rz.OdWniesienia == 1)
                                    {
                                        _odsetki.Od_Wniesienia = 1;
                                        _odsetki.DataOd = new DateTime(2000, 1, 1);
                                    }
                                    else
