                                        _odsetki.Od_Wniesienia = 0;
                                        diagnostic = "0.Błędna data początku okresu odsetkowego " + Convert.ToString(ry.numer) + " " + Convert.ToString(ry.kwota);
                                        _odsetki.DataOd = (DateTime)rz.DataPocz;
                                        diagnostic = String.Empty;
                                    }
                                    if (rz.DoZaplaty == 1)
